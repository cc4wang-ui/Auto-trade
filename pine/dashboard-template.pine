// ============================================================
// 宏觀相態儀表板 v2.0 | Macro Phase Dashboard
// 
// 理論基礎：
//   Module 1A - 橋水式經濟四季模型 + 銅金比先行校驗
//   Module 1B - 貨幣政策壓力鏈
//   Module 2  - 跨市場同步性 + 信用利差先行校驗
//   資產配置引擎 - 相態×因子 → 台股/台期/美股
//
// v2.0 核心升級：先行指標整合
//   每個滯後模組加入一個先行「校驗器」
//   先行指標不替代原模組，而是「確認或推翻」原模組的結論
//
//   ① 銅金比 → 校驗 Module 1A 成長指數
//      銅=工業需求，金=避險。比值下降=實體經濟弱化
//      領先 SPX 均線 6-8 週
//
//   ② VIX 期限結構 → 校驗 VIX 水位的「回歸假設」
//      VIX/VIX3M > 1 = Backwardation = 市場不認為恐慌會消退
//      改變 Module 3（未來）的回歸力判斷
//
//   ③ 信用利差 → 校驗 Module 2 同步性
//      HY Spread 高 = 企業違約風險升高 = 銀行收緊放貸
//      同步性降溫但利差仍高 = 假性平靜
//
// 使用方式：套用在任何日線圖上
// ============================================================
//@version=5
indicator("宏觀相態儀表板 v2.0", overlay=false, max_labels_count=500)

// ============================================================
// 參數設定 SETTINGS
// ============================================================
group_phase = "═══ Module 1A: 經濟相態 ═══"
lookback_short  = input.int(50,  "短期均線 (日)", minval=10, group=group_phase)
lookback_long   = input.int(200, "長期均線 (日)", minval=50, group=group_phase)
zscore_lookback = input.int(252, "Z-Score 回顧期 (約1年)", minval=100, group=group_phase)
roc_lookback    = input.int(20,  "變化率期間 (日)", minval=5, group=group_phase, tooltip="衡量各指標的方向變化速度")

group_policy = "═══ Module 1B: 貨幣政策 ═══"
policy_shock_thresh = input.float(10, "政策意外閾值 (2Y ROC%)", minval=3, maxval=30, group=group_policy, tooltip="2Y殖利率的20日變化率超過此值=市場正在劇烈重定價Fed路徑")
real_rate_warn      = input.float(2.0, "實質利率警戒線 (%)", minval=0.5, maxval=4.0, group=group_policy, tooltip="實質利率超過此值=金融條件過度緊縮")

group_sync = "═══ Module 2: 跨市場聯動 ═══"
corr_lookback = input.int(60, "相關性計算期 (日)", minval=20, group=group_sync)
sync_warn     = input.float(50, "同步性警戒線", minval=20, maxval=80, group=group_sync)
sync_danger   = input.float(70, "同步性危險線", minval=50, maxval=95, group=group_sync)

group_leading = "═══ 先行指標校驗 ═══"
cu_au_roc_len    = input.int(60, "銅金比 ROC 期間 (日)", minval=20, group=group_leading, tooltip="銅金比的變化率計算期間。60日約等於一季的趨勢")
credit_warn      = input.float(4.5, "信用利差警戒線 (%)", minval=2.0, maxval=8.0, group=group_leading, tooltip="HY 利差超過此值=信用市場開始收緊")
credit_danger    = input.float(6.0, "信用利差危險線 (%)", minval=3.0, maxval=12.0, group=group_leading, tooltip="HY 利差超過此值=嚴重信用緊縮")

group_display = "═══ 顯示設定 ═══"
show_table    = input.bool(true, "顯示儀表板", group=group_display)
show_bg       = input.bool(true, "顯示相態背景色", group=group_display)
show_trans    = input.bool(true, "顯示轉換警告線", group=group_display)
table_pos     = input.string("右上", "儀表板位置", options=["左上","右上","左下","右下"], group=group_display)

// ============================================================
// 數據獲取 DATA FETCHING
// 共 13 個 request.security (離上限 40 還有 27 個空間)
// ============================================================

// --- 成長 + 政策 Growth & Policy ---
us10y = request.security("TVC:US10Y",    "D", close, lookahead=barmerge.lookahead_off)
us02y = request.security("TVC:US02Y",    "D", close, lookahead=barmerge.lookahead_off)
spx   = request.security("SP:SPX",       "D", close, lookahead=barmerge.lookahead_off)
// v1.2 新增：有效聯邦基金利率 (Fed 的實際政策利率)
fedfunds = request.security("FRED:DFF",  "D", close, lookahead=barmerge.lookahead_off)

// --- 通膨 Inflation ---
breakeven = request.security("FRED:T10YIE", "D", close, lookahead=barmerge.lookahead_off)
dxy       = request.security("TVC:DXY",     "D", close, lookahead=barmerge.lookahead_off)
oil       = request.security("TVC:USOIL",   "D", close, lookahead=barmerge.lookahead_off)

// --- 跨市場 Cross-Asset ---
gold = request.security("TVC:GOLD", "D", close, lookahead=barmerge.lookahead_off)
twii = request.security("TVC:TWII", "D", close, lookahead=barmerge.lookahead_off)
vix  = request.security("CBOE:VIX", "D", close, lookahead=barmerge.lookahead_off)

// --- v2.0 先行指標 Leading Indicators ---
// 11. 銅 (工業需求的即時溫度計)
copper  = request.security("COMEX:HG1!", "D", close, lookahead=barmerge.lookahead_off)
// 12. VIX 3個月 (遠月波動率預期，用來跟近月VIX比較出期限結構)
vix3m   = request.security("CBOE:VIX3M", "D", close, lookahead=barmerge.lookahead_off)
// 13. 高收益債利差 (信用市場的恐懼指標)
hy_spread = request.security("FRED:BAMLH0A0HYM2", "D", close, lookahead=barmerge.lookahead_off)

// ============================================================
// 工具函數 UTILITIES
// ============================================================

zscore(float src, int len) =>
    float mean  = ta.sma(src, len)
    float stdev = ta.stdev(src, len)
    float result = stdev > 0 and not na(src) ? (src - mean) / stdev : 0.0
    math.max(-3.0, math.min(3.0, result))

safe_div(float a, float b) =>
    b != 0 and not na(b) ? a / b : 0.0

roc(float src, int len) =>
    not na(src) and not na(src[len]) and src[len] != 0 ? (src - src[len]) / math.abs(src[len]) * 100 : 0.0

// ============================================================
// MODULE 1A: 經濟相態偵測 (與 v1.1 相同)
// ============================================================

// ─── 殖利率曲線分析 ───
yield_curve   = us10y - us02y
yield_curve_z = zscore(yield_curve, zscore_lookback)
us10y_roc     = roc(us10y, roc_lookback)
us02y_roc     = roc(us02y, roc_lookback)

is_bear_steep = yield_curve > 0 and us10y_roc > us02y_roc and us10y_roc > 0
is_bull_steep = yield_curve > 0 and us02y_roc < us10y_roc and us02y_roc < 0
is_bear_flat  = yield_curve < 0.5 and us02y_roc > us10y_roc and us02y_roc > 0
is_bull_flat  = yield_curve < 0.5 and us10y_roc < us02y_roc and us10y_roc < 0

yc_growth_signal = yield_curve_z * (is_bear_steep ? 0.3 : 1.0)

yc_type = is_bear_steep ? "⚠ 熊陡" : is_bull_steep ? "牛陡" : is_bear_flat ? "熊平" : is_bull_flat ? "牛平" : "─"
yc_type_color = is_bear_steep ? color.orange : is_bull_steep ? color.green : is_bear_flat ? color.red : is_bull_flat ? color.blue : color.gray

// ─── SPX 動量 ───
spx_ma_short    = ta.sma(spx, lookback_short)
spx_ma_long     = ta.sma(spx, lookback_long)
spx_momentum    = safe_div(spx_ma_short - spx_ma_long, spx_ma_long) * 100
spx_momentum_z  = zscore(spx_momentum, zscore_lookback)
spx_momentum_roc = roc(spx_ma_short, roc_lookback)
spx_direction_z = zscore(spx_momentum_roc, zscore_lookback)

// ─── 綜合成長指數 ───
growth_index = yc_growth_signal * 0.3 + spx_momentum_z * 0.4 + spx_direction_z * 0.3

// ─── 通膨指數 ───
breakeven_z     = zscore(breakeven, zscore_lookback)
breakeven_roc   = roc(breakeven, roc_lookback)
breakeven_roc_z = zscore(breakeven_roc, zscore_lookback)

oil_ma_short   = ta.sma(oil, lookback_short)
oil_ma_long    = ta.sma(oil, lookback_long)
oil_momentum   = safe_div(oil_ma_short - oil_ma_long, oil_ma_long) * 100
oil_momentum_z = zscore(oil_momentum, zscore_lookback)

oil_20d_chg    = roc(oil, 20)
oil_shock      = math.abs(oil_20d_chg) > 30
oil_shock_up   = oil_20d_chg > 30
oil_shock_down = oil_20d_chg < -30

inflation_index = breakeven_z * 0.3 + breakeven_roc_z * 0.2 + oil_momentum_z * 0.5

// ─── 相態判定 ───
is_spring = growth_index > 0 and inflation_index <= 0
is_summer = growth_index > 0 and inflation_index > 0
is_autumn = growth_index <= 0 and inflation_index > 0
is_winter = growth_index <= 0 and inflation_index <= 0

phase_name  = is_spring ? "🟢 春 Goldilocks" : is_summer ? "🟠 夏 Overheating" : is_autumn ? "🔴 秋 Stagflation" : "🔵 冬 Deflation"
phase_color = is_spring ? color.green : is_summer ? color.orange : is_autumn ? color.red : color.blue

prev_phase_id = growth_index[1] > 0 ? (inflation_index[1] > 0 ? 2 : 1) : (inflation_index[1] > 0 ? 3 : 4)
curr_phase_id = growth_index > 0 ? (inflation_index > 0 ? 2 : 1) : (inflation_index > 0 ? 3 : 4)
phase_changed = curr_phase_id != prev_phase_id

growth_stability    = math.min(math.abs(growth_index) / 1.5, 1.0) * 100
inflation_stability = math.min(math.abs(inflation_index) / 1.5, 1.0) * 100
phase_stability     = math.min(growth_stability, inflation_stability)

stability_label = phase_stability > 70 ? "穩定" : phase_stability > 40 ? "⚠ 鬆動" : "⚠⚠ 接近轉換"
stability_color = phase_stability > 70 ? color.green : phase_stability > 40 ? color.yellow : color.red

next_phase_if_growth_flips = growth_index > 0 ? 
     (inflation_index > 0 ? "秋 Stagflation" : "冬 Deflation") : 
     (inflation_index > 0 ? "夏 Overheating" : "春 Goldilocks")

phase_equity_bias = is_spring ? 2.0 : is_summer ? 1.0 : is_winter ? -1.0 : -2.0

// ============================================================
// MODULE 1B: 貨幣政策壓力鏈 MONETARY POLICY PRESSURE
// ============================================================
//
// ▎核心邏輯：物價數據如何影響你的部位
//
// 傳導路徑（每一步都可以在儀表板上追蹤）：
//
//   ① 物價數據公布 (PPI/CPI/PCE 超預期)
//      ↓
//   ② 市場重定價 Fed 路徑 (2Y殖利率立即反應)
//      ↓
//   ③ 實質利率上升 (名目利率漲 + 降息預期消失)
//      ↓
//   ④ 金融條件收緊 (美元強 + 借貸成本高 + 信用收縮)
//      ↓
//   ⑤ 風險資產承壓 (股票估值壓縮、新興市場資金外流)
//
// 物理類比：這是一個「壓力傳導系統」
//   物價上漲 = 管道裡的水壓升高
//   Fed = 閥門（調節壓力的機制，但反應有延遲）
//   2Y殖利率 = 壓力計（即時顯示市場感受到的壓力）
//   實質利率 = 最終傳導到實體經濟的有效壓力
//   當水壓（通膨）持續升高而閥門（Fed）無法降壓
//   整條管道（金融系統）就會承受越來越大的壓力
//
// ============================================================

// ─── ① 政策利率基準 ───
// Fed Funds Rate = Fed 目前的實際政策利率
// 這是「閥門」的當前位置
ff_rate = nz(fedfunds, us02y)  // fallback: 若 FRED:DFF 無資料，用 2Y 近似

// ─── ② 政策預期差 (Policy Expectation Gap) ───
// 2Y殖利率 - Fed Funds = 市場對「未來政策」的即時投票
//   正值 = 市場預期 Fed 會升息（或不降息比預期久）
//   負值 = 市場預期 Fed 會降息
//   接近零 = 市場認為 Fed 不會動
//
// 2022年案例：這個差從年初的負值（預期降息）
// 一路飆到正值（原來要升息！），SPX 就是這樣崩的
// 2026年現在：PPI超預期 → 這個差又在擴大中
policy_gap      = us02y - ff_rate
policy_gap_z    = zscore(policy_gap, zscore_lookback)
policy_gap_roc  = roc(policy_gap, roc_lookback)

// 政策方向判定
policy_dir = policy_gap > 0.25 ? "鷹" : policy_gap < -0.25 ? "鴿" : "中性"

// ─── ③ 政策意外偵測 (Policy Repricing Shock) ───
// 2Y殖利率的變化率 = 市場正在多快速地重新定價Fed
// 當 PPI/CPI 數據炸裂時，2Y 會在當天就劇烈反應
// 這比等下個月的 CPI 更即時
us02y_20d_roc = roc(us02y, roc_lookback)

// 政策意外判定
// 正向意外 = 2Y急升 = 市場在說「Fed要更鷹了」（壞消息）
// 負向意外 = 2Y急跌 = 市場在說「Fed要轉鴿了」（好消息）
policy_shock_hawk = us02y_20d_roc > policy_shock_thresh
policy_shock_dove = us02y_20d_roc < -policy_shock_thresh
policy_shock_any  = policy_shock_hawk or policy_shock_dove

// ─── ④ 實質利率分析 (Real Interest Rate) ───
// 實質利率 = 名目利率 - 通膨預期
// 這是「真正的資金成本」
//
// 為什麼重要？
// - 名目利率 4% + 通膨預期 3% = 實質利率 1% (還行)
// - 名目利率 4% + 通膨預期 2% = 實質利率 2% (很緊)
// - 名目利率 4% + 通膨預期 4% = 實質利率 0% (寬鬆)
//
// 2022年：實質利率從 -1% 飆到 +1.5%，股市崩了27%
// 2026年現在：實質利率在上升中（因為Fed不降息+通膨預期被壓住）
real_rate_10y = us10y - nz(breakeven, 2.5)  // 10年期實質利率
real_rate_02y = us02y - nz(breakeven, 2.5)  // 2年期實質利率（更敏感）

real_rate_z   = zscore(real_rate_10y, zscore_lookback)
real_rate_roc = roc(real_rate_10y, roc_lookback)

// 實質利率狀態
real_rate_level = real_rate_10y >= real_rate_warn ? "🔴 過緊" : real_rate_10y >= 1.0 ? "🟡 偏緊" : real_rate_10y >= 0 ? "正常" : "🟢 寬鬆"
real_rate_color = real_rate_10y >= real_rate_warn ? color.red : real_rate_10y >= 1.0 ? color.orange : real_rate_10y >= 0 ? color.gray : color.green

// ─── ⑤ 金融緊縮度指數 (Financial Tightness Index) ───
// 綜合衡量「金融管道裡的壓力有多大」
//
// 組成：
//   - 實質利率 Z-score (權重 40%)：越高=借錢越貴=越緊
//   - 美元強度 Z-score (權重 30%)：越強=全球美元流動性越緊
//   - 殖利率曲線倒掛深度 Z-score (權重 30%)：越倒掛=銀行越不想放貸
//
// 最終輸出是一個 -3 到 +3 的指數
//   正值 = 金融條件在收緊 (對股票不利)
//   負值 = 金融條件在放鬆 (對股票有利)
//   >1.5 = 嚴重緊縮 (開始傷害實體經濟)
dxy_z = zscore(dxy, zscore_lookback)

// 殖利率曲線倒掛越深 = 越緊 → 反轉符號
yc_tightness_z = -yield_curve_z  // 倒掛(負值)變成正的tightness

financial_tightness = real_rate_z * 0.4 + dxy_z * 0.3 + yc_tightness_z * 0.3
ft_level = financial_tightness > 1.5 ? "🔴 嚴重緊縮" : financial_tightness > 0.5 ? "🟡 偏緊" : financial_tightness > -0.5 ? "中性" : "🟢 寬鬆"
ft_color = financial_tightness > 1.5 ? color.red : financial_tightness > 0.5 ? color.orange : financial_tightness > -0.5 ? color.gray : color.green

// ─── 金融緊縮度的變化方向 ───
ft_ma    = ta.sma(financial_tightness, 10)
ft_rising = financial_tightness > ft_ma

// ─── 貨幣政策對股票的綜合壓力 ───
// 這個值會被加進最終的 macro_score
//   正值 = 政策在幫忙（寬鬆）
//   負值 = 政策在拖累（緊縮）
//
// 計算：
//   基礎 = 金融緊縮度的反向 (緊縮=負分)
//   政策意外修正 = 鷹派衝擊額外扣分
//   實質利率過高修正 = 額外扣分
policy_pressure = -financial_tightness * 8.0  // 基礎 (約 ±24)
policy_shock_mod = policy_shock_hawk ? -10.0 : policy_shock_dove ? 5.0 : 0.0
real_rate_extreme_mod = real_rate_10y > real_rate_warn ? -8.0 : 0.0

policy_score = policy_pressure + policy_shock_mod + real_rate_extreme_mod
policy_score_clamped = math.max(-30.0, math.min(15.0, policy_score))

// ============================================================
// 資產配置建議引擎 ASSET ALLOCATION ENGINE
// ============================================================
//
// ▎設計原理：
//   每個交易工具對宏觀因子有不同的敏感度
//   不能用同一把尺量所有市場
//
// ▎台股現股的獨特風險：
//   - 台灣是能源淨進口國 → 油價暴漲直接侵蝕企業利潤
//   - 台股權值集中在半導體 → 對實質利率高度敏感（成長股估值邏輯）
//   - 外資佔比高 → 美元走強時外資傾向匯出
//
// ▎台指期的特性：
//   - 可做空 → 在偏空環境下是工具而非只能觀望
//   - 短天期 → 更適合用中短期訊號驅動
//   - 槓桿 → 在高同步性（系統風險高）時應縮小部位
//
// ▎美股的特性：
//   - 成長股 vs 價值股對實質利率的反應完全相反
//   - 能源獨立 → 油價衝擊相對台灣輕
//   - 美元計價 → 不受匯率損失
//
// 評分範圍：每個資產 -3 到 +3
//   +3 = 強烈做多    +1~+2 = 偏多
//    0 = 觀望       -1~-2 = 偏空/減碼
//   -3 = 強烈做空/清倉
// ============================================================

// ─── 台股現股評分 ───
// 基礎：跟著相態走
float tw_stock_base = phase_equity_bias  // -2 to +2

// 油價修正：台灣是能源進口國，油價衝擊的傷害比美國大
float tw_oil_mod = oil_shock_up ? -1.0 : oil_momentum_z > 1.0 ? -0.5 : oil_momentum_z < -1.0 ? 0.3 : 0.0

// 美元修正：DXY 強 → 外資撤出台灣機率升高
float tw_dxy_mod = dxy_z > 1.5 ? -0.5 : dxy_z > 0.5 ? -0.25 : dxy_z < -0.5 ? 0.25 : 0.0

// 實質利率修正：台股權值=半導體=成長股=對利率超敏感
float tw_rate_mod = real_rate_z > 1.5 ? -0.5 : real_rate_z > 0.5 ? -0.25 : real_rate_z < -0.5 ? 0.25 : 0.0

float tw_stock_score = math.max(-3.0, math.min(3.0, tw_stock_base + tw_oil_mod + tw_dxy_mod + tw_rate_mod))

// v2.0: 銅金比分歧 override — 先行指標說經濟在弱化，所有資產都要額外減碼
float leading_override = growth_divergence_bear ? -0.5 : growth_divergence_bull ? 0.25 : 0.0
tw_stock_score := math.max(-3.0, math.min(3.0, tw_stock_score + leading_override))

// ─── 台指期評分 ───
// 基礎同上，但可做空所以偏空時給正向空方分數
float tw_fut_base = phase_equity_bias

// 同步性修正：高同步=系統風險=縮小槓桿部位（不論方向）
float tw_fut_sync_mod = sync_index >= sync_danger ? -0.5 : 0.0  // 不論多空都縮小

// VIX修正：恐慌時期期貨波動加大，部位要更保守
float tw_fut_vix_mod = vix_z > 1.5 ? -0.3 : 0.0

// 台指期：跟台股相同的油+匯率+利率因子
float tw_fut_score_raw = tw_fut_base + tw_oil_mod + tw_dxy_mod + tw_rate_mod + tw_fut_sync_mod + tw_fut_vix_mod
float tw_fut_score = math.max(-3.0, math.min(3.0, tw_fut_score_raw))
tw_fut_score := math.max(-3.0, math.min(3.0, tw_fut_score + leading_override))

// ─── 美股評分 ───
// 基礎：相態
float us_stock_base = phase_equity_bias

// 油價修正：美國能源獨立，油價衝擊相對溫和
float us_oil_mod = oil_shock_up ? -0.3 : 0.0  // 比台灣的-1.0輕很多

// 實質利率修正：對美股成長股（科技）衝擊最大
float us_rate_mod = real_rate_z > 1.5 ? -0.75 : real_rate_z > 0.5 ? -0.35 : real_rate_z < -0.5 ? 0.35 : 0.0

// 金融緊縮度修正
float us_ft_mod = financial_tightness > 1.5 ? -0.5 : financial_tightness > 0.5 ? -0.25 : financial_tightness < -0.5 ? 0.25 : 0.0

float us_stock_score = math.max(-3.0, math.min(3.0, us_stock_base + us_oil_mod + us_rate_mod + us_ft_mod))
us_stock_score := math.max(-3.0, math.min(3.0, us_stock_score + leading_override))

// ─── 評分轉文字 ───
asset_label(float score) =>
    score >= 2.5  ? "🟢 積極做多" :
     score >= 1.5  ? "🟢 偏多" :
     score >= 0.5  ? "△ 輕倉做多" :
     score > -0.5  ? "─ 觀望" :
     score > -1.5  ? "▽ 減碼/輕空" :
     score > -2.5  ? "🔴 偏空" :
     "🔴 強烈偏空/清倉"

asset_color(float score) =>
    score >= 1.5 ? color.green : score >= 0.5 ? color.lime : score > -0.5 ? color.gray : score > -1.5 ? color.orange : color.red

// ============================================================
// MODULE 2: 跨市場同步性 (與 v1.1 相同)
// ============================================================

spx_ret  = safe_div(ta.change(spx), spx[1])
twii_ret = safe_div(ta.change(twii), twii[1])
gold_ret = safe_div(ta.change(gold), gold[1])
dxy_ret  = safe_div(ta.change(dxy), dxy[1])
oil_ret  = safe_div(ta.change(oil), oil[1])
bond_ret = -ta.change(us10y)

c_spx_twii  = math.abs(ta.correlation(spx_ret, twii_ret, corr_lookback))
c_spx_gold  = math.abs(ta.correlation(spx_ret, gold_ret, corr_lookback))
c_spx_dxy   = math.abs(ta.correlation(spx_ret, dxy_ret, corr_lookback))
c_spx_bond  = math.abs(ta.correlation(spx_ret, bond_ret, corr_lookback))
c_spx_oil   = math.abs(ta.correlation(spx_ret, oil_ret, corr_lookback))
c_twii_gold = math.abs(ta.correlation(twii_ret, gold_ret, corr_lookback))
c_twii_dxy  = math.abs(ta.correlation(twii_ret, dxy_ret, corr_lookback))
c_twii_bond = math.abs(ta.correlation(twii_ret, bond_ret, corr_lookback))
c_gold_dxy  = math.abs(ta.correlation(gold_ret, dxy_ret, corr_lookback))
c_gold_bond = math.abs(ta.correlation(gold_ret, bond_ret, corr_lookback))

float pair_count = 10.0
sync_sum = nz(c_spx_twii) + nz(c_spx_gold) + nz(c_spx_dxy) + nz(c_spx_bond) + nz(c_spx_oil) + nz(c_twii_gold) + nz(c_twii_dxy) + nz(c_twii_bond) + nz(c_gold_dxy) + nz(c_gold_bond)
sync_index = (sync_sum / pair_count) * 100

sync_index_ma = ta.sma(sync_index, 10)
sync_rising   = sync_index > sync_index_ma

sync_level = sync_index >= sync_danger ? "🔴 極高" : sync_index >= sync_warn ? "🟡 偏高" : "🟢 正常"
sync_color = sync_index >= sync_danger ? color.red : sync_index >= sync_warn ? color.orange : color.green
sync_dir   = sync_rising ? " ↑" : " ↓"

// ============================================================
// 先行指標校驗層 LEADING INDICATOR VALIDATION
// ============================================================
//
// ▎設計原則：不是加更多訊號，而是「確認或推翻」滯後模組
//
// 每個先行指標只做一件事：
//   跟對應的滯後模組比對，如果兩者矛盾，發出「分歧警報」
//   如果一致，增加確信度
//
// ============================================================

// ─── ① 銅金比 → 校驗 Module 1A 成長指數 ───
//
// 銅 = 工業需求溫度計（經濟好 → 需求高 → 銅漲）
// 金 = 避險需求溫度計（經濟差 → 恐懼高 → 金漲）
// 比值下降 = 實體經濟弱化 + 避險升溫
//
// 領先 SPX 50/200 均線 6-8 週
// 來源：DoubleLine (Jeffrey Gundlach) 將其視為最重要的先行指標之一

float cu_au_ratio = safe_div(copper, gold) * 1000  // 乘1000讓數值可讀
float cu_au_ratio_roc = roc(cu_au_ratio, cu_au_roc_len)  // 60日變化率
float cu_au_z = zscore(cu_au_ratio, zscore_lookback)

// 銅金比 vs 成長指數的分歧偵測
// 分歧 = 銅金比已經在說「經濟在弱化」，但成長指數還在正值（均線還沒反應）
bool cu_au_bearish = cu_au_z < -0.5 and cu_au_ratio_roc < -10  // 銅金比明確下降
bool cu_au_bullish = cu_au_z > 0.5 and cu_au_ratio_roc > 10    // 銅金比明確上升

// 分歧狀態
bool growth_divergence_bear = cu_au_bearish and growth_index > 0   // 先行看壞但滯後還樂觀
bool growth_divergence_bull = cu_au_bullish and growth_index < 0   // 先行看好但滯後還悲觀

string cu_au_status = growth_divergence_bear ? "⚠ 先行背離！" : growth_divergence_bull ? "🔵 先行轉好" : cu_au_bearish ? "↓ 弱化" : cu_au_bullish ? "↑ 強化" : "─ 中性"
color cu_au_color = growth_divergence_bear ? color.red : growth_divergence_bull ? color.blue : cu_au_bearish ? color.orange : cu_au_bullish ? color.green : color.gray

// ─── ② VIX 期限結構 → 校驗波動率回歸假設 ───
//
// VIX = 30日預期波動率（近月）
// VIX3M = 3個月預期波動率（遠月）
//
// 正常 (Contango): VIX < VIX3M → 比值 < 1 → 市場認為恐慌會消退
// 異常 (Backwardation): VIX > VIX3M → 比值 > 1 → 市場認為恐慌會持續或加劇
//
// 2022案例：VIX 期限結構在 1 月就扁平化，比主跌段早 2 個月

float vix_term = safe_div(vix, nz(vix3m, vix))  // 比值。>1 = backwardation
float vix_term_ma = ta.sma(vix_term, 10)

bool is_backwardation = vix_term > 1.0         // 近月 > 遠月 = 搶短期保護
bool is_deep_backwardation = vix_term > 1.1    // 嚴重倒掛 = 極度恐慌預期
bool is_contango = vix_term < 0.9              // 正常 = 恐慌預期消退中

string vix_term_status = is_deep_backwardation ? "🔴 深度倒掛" : is_backwardation ? "🟡 倒掛" : is_contango ? "🟢 正常" : "─ 扁平"
color vix_term_color = is_deep_backwardation ? color.red : is_backwardation ? color.orange : is_contango ? color.green : color.gray

// VIX 倒掛推翻「回歸假設」
// 如果 Module 3（未來）假設 VIX 會回歸均值，但期限結構說不會 → 防禦時間要拉長
// 目前直接影響綜合評分：倒掛時額外扣分

// ─── ③ 信用利差 → 校驗 Module 2 同步性 ───
//
// BAMLH0A0HYM2 = ICE BofA 高收益債選擇權調整利差
// 反映的是：市場覺得垃圾債（高風險企業）多容易違約
//
// 利差擴大 → 銀行收緊放貸 → 企業投資下降 → 經濟放緩 → 股票跌
// 通常領先股票相關性上升 2-4 週
//
// 關鍵場景：同步性開始降溫（看起來危機過去了），但利差仍高
// → 表面平靜但底層壓力沒解除 = 假性復甦

float hy_spread_val = nz(hy_spread, 0)
float hy_spread_z = zscore(hy_spread_val, zscore_lookback)
float hy_spread_roc = roc(hy_spread_val, roc_lookback)

bool credit_stress = hy_spread_val > credit_warn
bool credit_crisis = hy_spread_val > credit_danger

// 同步性 vs 信用利差的分歧偵測
// 最危險的情況：同步性回落（看似平靜）但利差仍在高位或持續擴大
bool false_calm = sync_index < sync_warn and credit_stress and hy_spread_roc > 0

string credit_status = credit_crisis ? "🔴 信用危機" : false_calm ? "⚠ 假性平靜！" : credit_stress ? "🟡 偏緊" : "🟢 正常"
color credit_color = credit_crisis ? color.red : false_calm ? color.orange : credit_stress ? color.yellow : color.green

// ============================================================
// 綜合宏觀評分 COMPOSITE MACRO SCORE
// ============================================================
//
// v2.0 評分邏輯：
//   1. 相態基礎分 (±60)
//   2. 成長動量修正 (±20)
//   3. 貨幣政策壓力 (-30 ~ +15)
//   4. 同步性風險修正 (-15 ~ 0)
//   5. VIX 修正 (-15 ~ +5)
//   6. 油價衝擊修正 (-15 ~ 0)
//   7. 熊陡修正 (-10 ~ 0)
//   --- v2.0 先行校驗 ---
//   8. 銅金比分歧修正 (-10 ~ +5)  ← 先行看壞但滯後沒反應=額外扣分
//   9. VIX 期限結構修正 (-10 ~ 0) ← 倒掛=恐慌不會消退=額外扣分
//  10. 信用利差修正 (-10 ~ 0)     ← 假性平靜=額外扣分
//   → 裁剪到 -100 ~ +100
// ============================================================

base_score      = phase_equity_bias * 30.0
growth_modifier = growth_index * 10.0

// v1.2: 貨幣政策壓力直接加入
// policy_score_clamped 已在 Module 1B 計算

sync_penalty    = sync_index >= sync_danger ? -15.0 : sync_index >= sync_warn ? -5.0 : 0.0

vix_z       = zscore(vix, zscore_lookback)
vix_penalty = vix_z > 2.0 ? -15.0 : vix_z > 1.0 ? -5.0 : vix_z < -1.0 ? 5.0 : 0.0

oil_shock_penalty  = oil_shock_up ? -15.0 : oil_shock_down ? -5.0 : 0.0
bear_steep_penalty = is_bear_steep ? -10.0 : 0.0

// v2.0 先行指標修正
// 銅金比分歧：先行指標看壞但滯後還在正值 → 額外扣分（你比你以為的更危險）
//            先行指標看好但滯後還在負值 → 小幅加分（底部可能近了）
float cu_au_mod = growth_divergence_bear ? -10.0 : growth_divergence_bull ? 5.0 : 0.0

// VIX 期限結構：倒掛代表市場不認為恐慌會消退 → 防禦時間拉長
float vix_term_mod = is_deep_backwardation ? -10.0 : is_backwardation ? -5.0 : 0.0

// 信用利差：假性平靜是最危險的 → 額外扣分
float credit_mod = credit_crisis ? -10.0 : false_calm ? -8.0 : credit_stress ? -3.0 : 0.0

macro_score_raw = base_score + growth_modifier + policy_score_clamped + sync_penalty + vix_penalty + oil_shock_penalty + bear_steep_penalty + cu_au_mod + vix_term_mod + credit_mod
macro_score = math.max(-100.0, math.min(100.0, macro_score_raw))

macro_label      = macro_score > 50 ? "強烈偏多" : macro_score > 20 ? "偏多" : macro_score > -20 ? "中性" : macro_score > -50 ? "偏空" : "強烈偏空"
macro_text_color = macro_score > 50 ? color.green : macro_score > 20 ? color.lime : macro_score > -20 ? color.gray : macro_score > -50 ? color.orange : color.red
macro_action     = macro_score > 50 ? "積極做多，正常部位" : macro_score > 20 ? "偏多但控制規模" : macro_score > -20 ? "觀望，降低曝險" : macro_score > -50 ? "偏空或避險為主" : "全面防禦，最小部位"

// ============================================================
// 繪圖 PLOTS
// ============================================================

p_growth    = plot(growth_index, "成長指數", color=color.new(color.teal, 0), linewidth=2)
p_inflation = plot(inflation_index, "通膨指數", color=color.new(color.orange, 0), linewidth=2)
p_zero      = plot(0.0, "零軸", color=color.new(color.gray, 60))

fill(p_growth, p_zero, color=growth_index > 0 ? color.new(color.teal, 85) : color.new(color.red, 85))

// 同步性
plot(sync_index / 50.0 - 1.0, "同步性 (scaled)", color=color.new(color.yellow, 50), linewidth=1, style=plot.style_stepline)

// v1.2: 金融緊縮度 (紫色線)
plot(financial_tightness, "金融緊縮度", color=color.new(color.purple, 30), linewidth=1, style=plot.style_line)

bgcolor(show_bg ? color.new(phase_color, 92) : na)

transition_zone_hi = show_trans ? 0.3 : na
transition_zone_lo = show_trans ? -0.3 : na
p_tz_hi = plot(transition_zone_hi, "轉換區上緣", color=color.new(color.white, 80), style=plot.style_circles)
p_tz_lo = plot(transition_zone_lo, "轉換區下緣", color=color.new(color.white, 80), style=plot.style_circles)

plotshape(phase_changed, "相態轉換", shape.diamond, location.top, color=color.white, size=size.small)
plotshape(oil_shock_up, "油價急漲衝擊", shape.triangleup, location.bottom, color=color.red, size=size.tiny, text="OIL")
plotshape(oil_shock_down, "油價急跌衝擊", shape.triangledown, location.bottom, color=color.blue, size=size.tiny, text="OIL")

// v1.2: 政策意外標記
plotshape(policy_shock_hawk, "鷹派政策衝擊", shape.xcross, location.top, color=color.red, size=size.tiny, text="HAWK")
plotshape(policy_shock_dove, "鴿派政策衝擊", shape.xcross, location.bottom, color=color.green, size=size.tiny, text="DOVE")

// v2.0: 先行指標警報標記
plotshape(growth_divergence_bear, "銅金比背離", shape.flag, location.top, color=color.fuchsia, size=size.tiny, text="Cu/Au")
plotshape(false_calm, "假性平靜", shape.flag, location.bottom, color=color.orange, size=size.tiny, text="CREDIT")

plot(macro_score / 50.0, "綜合評分 (scaled)", color=macro_text_color, linewidth=1, style=plot.style_stepline_diamond)

// ============================================================
// 儀表板表格 DASHBOARD TABLE
// 表格行數：標題1 + M1A(11) + M1B(8) + M2(8) + 綜合(5) = 33
// ============================================================

get_table_pos(string pos) =>
    pos == "左上" ? position.top_left : pos == "右上" ? position.top_right : pos == "左下" ? position.bottom_left : position.bottom_right

var table dash = table.new(get_table_pos(table_pos), 3, 48, bgcolor=color.new(#1a1a2e, 0), border_width=1, border_color=color.new(color.gray, 70))

if barstate.islast and show_table
    int row = 0

    // ═══════════════════════════════
    // 標題
    // ═══════════════════════════════
    table.cell(dash, 0, row, "  宏觀相態儀表板 v2.0  ", text_color=color.white, text_size=size.normal, bgcolor=color.new(#16213e, 0))
    table.merge_cells(dash, 0, row, 2, row)
    row += 1

    // ═══════════════════════════════
    // MODULE 1A：經濟相態
    // ═══════════════════════════════
    table.cell(dash, 0, row, " ▎經濟相態 Economic Phase ", text_color=#00d2ff, text_size=size.small, bgcolor=color.new(#0f3460, 0))
    table.merge_cells(dash, 0, row, 2, row)
    row += 1

    table.cell(dash, 0, row, " 當前相態", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, phase_name, text_color=color.white, text_size=size.small, bgcolor=color.new(phase_color, 60))
    table.merge_cells(dash, 1, row, 2, row)
    row += 1

    table.cell(dash, 0, row, " 穩定度", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(phase_stability, "#") + "%", text_color=stability_color, text_size=size.small)
    table.cell(dash, 2, row, stability_label, text_color=stability_color, text_size=size.small)
    row += 1

    string next_hint = phase_stability <= 40 ? "→ 可能轉入 " + next_phase_if_growth_flips : ""
    table.cell(dash, 0, row, next_hint != "" ? " 轉換預警" : "", text_color=color.red, text_size=size.tiny)
    table.cell(dash, 1, row, next_hint, text_color=color.red, text_size=size.tiny)
    table.merge_cells(dash, 1, row, 2, row)
    row += 1

    table.cell(dash, 0, row, " 成長指數", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(growth_index, "#.##"), text_color=growth_index > 0 ? color.green : color.red, text_size=size.small)
    table.cell(dash, 2, row, growth_index > 1 ? "▲ 強擴張" : growth_index > 0 ? "△ 擴張" : growth_index > -1 ? "▽ 收縮" : "▼ 強收縮", text_color=growth_index > 0 ? color.green : color.red, text_size=size.small)
    row += 1

    table.cell(dash, 0, row, " 通膨指數", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(inflation_index, "#.##"), text_color=inflation_index > 0.5 ? color.red : inflation_index > 0 ? color.orange : color.teal, text_size=size.small)
    table.cell(dash, 2, row, inflation_index > 1 ? "▲ 過熱" : inflation_index > 0 ? "△ 升溫" : inflation_index > -1 ? "▽ 降溫" : "▼ 通縮", text_color=inflation_index > 0 ? color.orange : color.teal, text_size=size.small)
    row += 1

    // 子指標
    table.cell(dash, 0, row, "   殖利率曲線", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(yield_curve, "#.##") + "%", text_color=yield_curve > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, row, yc_type, text_color=yc_type_color, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "   SPX 動量", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(spx_momentum, "#.#") + "%", text_color=spx_momentum > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, row, spx_momentum_roc > 0 ? " ↑加速" : " ↓減速", text_color=spx_momentum_roc > 0 ? color.green : color.red, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "   通膨預期", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, not na(breakeven) ? str.tostring(breakeven, "#.##") + "%" : "N/A", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 2, row, not na(breakeven) ? (breakeven_roc > 0 ? " ↑升溫" : " ↓降溫") : "", text_color=breakeven_roc > 0 ? color.orange : color.teal, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "   原油動量", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(oil_momentum, "#.#") + "%", text_color=oil_momentum > 0 ? color.orange : color.teal, text_size=size.tiny)
    string oil_warn = oil_shock_up ? "🔴 急漲衝擊!" : oil_shock_down ? "🔵 急跌衝擊!" : str.tostring(oil_20d_chg, "#.#") + "% (20D)"
    table.cell(dash, 2, row, oil_warn, text_color=oil_shock_up ? color.red : oil_shock_down ? color.blue : (oil_20d_chg > 0 ? color.orange : color.teal), text_size=size.tiny)
    row += 1

    // ═══════════════════════════════
    // MODULE 1B：貨幣政策壓力
    // ═══════════════════════════════
    table.cell(dash, 0, row, " ▎貨幣政策壓力 Policy Chain ", text_color=#e040fb, text_size=size.small, bgcolor=color.new(#3c0f60, 0))
    table.merge_cells(dash, 0, row, 2, row)
    row += 1

    // 傳導鏈第一步：Fed 基準利率
    table.cell(dash, 0, row, " Fed 基準利率", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(ff_rate, "#.##") + "%", text_color=color.white, text_size=size.small)
    table.cell(dash, 2, row, "", text_size=size.small)
    row += 1

    // 第二步：政策預期差
    table.cell(dash, 0, row, " 政策預期差", text_color=color.silver, text_size=size.small)
    string pg_val = str.tostring(policy_gap, "#.##") + "%"
    color pg_color = policy_gap > 0.25 ? color.red : policy_gap < -0.25 ? color.green : color.gray
    string pg_label = policy_gap > 0.5 ? "🔴 強鷹 (不降息)" : policy_gap > 0.25 ? "🟡 偏鷹" : policy_gap > -0.25 ? "中性" : policy_gap > -0.5 ? "🟢 偏鴿" : "🟢 強鴿 (降息預期)"
    table.cell(dash, 1, row, pg_val, text_color=pg_color, text_size=size.small)
    table.cell(dash, 2, row, pg_label, text_color=pg_color, text_size=size.small)
    row += 1

    // 第三步：政策意外
    string shock_label = policy_shock_hawk ? "🔴 鷹派衝擊!" : policy_shock_dove ? "🟢 鴿派衝擊!" : "─ 無"
    color shock_color = policy_shock_hawk ? color.red : policy_shock_dove ? color.green : color.gray
    table.cell(dash, 0, row, " 政策意外", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(us02y_20d_roc, "#.#") + "% (2Y ROC)", text_color=shock_color, text_size=size.small)
    table.cell(dash, 2, row, shock_label, text_color=shock_color, text_size=size.small)
    row += 1

    // 第四步：實質利率
    table.cell(dash, 0, row, " 實質利率", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(real_rate_10y, "#.##") + "%", text_color=real_rate_color, text_size=size.small)
    string rr_dir = real_rate_roc > 0 ? " ↑收緊中" : " ↓放鬆中"
    table.cell(dash, 2, row, real_rate_level + rr_dir, text_color=real_rate_color, text_size=size.small)
    row += 1

    // 第五步：金融緊縮度
    table.cell(dash, 0, row, " 金融緊縮度", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(financial_tightness, "#.##"), text_color=ft_color, text_size=size.small)
    string ft_dir_label = ft_rising ? " ↑惡化中" : " ↓改善中"
    table.cell(dash, 2, row, ft_level + ft_dir_label, text_color=ft_color, text_size=size.small)
    row += 1

    // 政策壓力對評分的影響
    table.cell(dash, 0, row, "   政策評分", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(policy_score_clamped, "#.#"), text_color=policy_score_clamped > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, row, policy_score_clamped > 5 ? "助力" : policy_score_clamped > -5 ? "中性" : "拖累", text_color=policy_score_clamped > 5 ? color.green : policy_score_clamped > -5 ? color.gray : color.red, text_size=size.tiny)
    row += 1

    // ═══════════════════════════════
    // MODULE 2：跨市場聯動
    // ═══════════════════════════════
    table.cell(dash, 0, row, " ▎跨市場聯動 Cross-Asset ", text_color=#00d2ff, text_size=size.small, bgcolor=color.new(#0f3460, 0))
    table.merge_cells(dash, 0, row, 2, row)
    row += 1

    table.cell(dash, 0, row, " 同步性指數", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(sync_index, "#.#") + sync_dir, text_color=sync_color, text_size=size.small)
    table.cell(dash, 2, row, sync_level, text_color=sync_color, text_size=size.small)
    row += 1

    float spx_20d  = safe_div(spx - spx[20], spx[20]) * 100
    float twii_20d = safe_div(twii - twii[20], twii[20]) * 100
    float gold_20d = safe_div(gold - gold[20], gold[20]) * 100
    float dxy_20d  = safe_div(dxy - dxy[20], dxy[20]) * 100
    float oil_20d  = safe_div(oil - oil[20], oil[20]) * 100

    table.cell(dash, 0, row, "   SPX 20日", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(spx_20d, "#.#") + "%", text_color=spx_20d > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, row, "", text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "   台股 20日", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(twii_20d, "#.#") + "%", text_color=twii_20d > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, row, "", text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "   黃金 20日", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(gold_20d, "#.#") + "%", text_color=gold_20d > 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, row, "", text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "   美元 20日", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(dxy_20d, "#.#") + "%", text_color=dxy_20d > 0 ? color.lime : color.orange, text_size=size.tiny)
    table.cell(dash, 2, row, "", text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "   原油 20日", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(oil_20d, "#.#") + "%", text_color=oil_20d > 0 ? color.orange : color.teal, text_size=size.tiny)
    table.cell(dash, 2, row, "", text_size=size.tiny)
    row += 1

    // ═══════════════════════════════
    // 先行指標校驗
    // ═══════════════════════════════
    table.cell(dash, 0, row, " ▎先行指標校驗 Leading ", text_color=#ff6090, text_size=size.small, bgcolor=color.new(#600020, 0))
    table.merge_cells(dash, 0, row, 2, row)
    row += 1

    // 銅金比
    table.cell(dash, 0, row, " 銅金比 Cu/Au", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(cu_au_ratio_roc, "#.#") + "% (60D)", text_color=cu_au_color, text_size=size.small)
    table.cell(dash, 2, row, cu_au_status, text_color=cu_au_color, text_size=size.small)
    row += 1

    // 銅金比 vs 成長指數對照
    table.cell(dash, 0, row, "   vs 成長指數", text_color=color.new(color.silver, 30), text_size=size.tiny)
    string cu_vs_growth = growth_divergence_bear ? "背離！先行↓ 滯後仍↑" : growth_divergence_bull ? "背離！先行↑ 滯後仍↓" : "一致"
    color cu_vs_color = growth_divergence_bear ? color.red : growth_divergence_bull ? color.blue : color.gray
    table.cell(dash, 1, row, cu_vs_growth, text_color=cu_vs_color, text_size=size.tiny)
    table.merge_cells(dash, 1, row, 2, row)
    row += 1

    // VIX 期限結構
    table.cell(dash, 0, row, " VIX 期限結構", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, str.tostring(vix_term, "#.##"), text_color=vix_term_color, text_size=size.small)
    table.cell(dash, 2, row, vix_term_status, text_color=vix_term_color, text_size=size.small)
    row += 1

    // VIX 期限結構含義
    string vix_term_hint = is_backwardation ? "恐慌預期持續，不宜抄底" : is_contango ? "恐慌消退中，回歸力增強" : "觀望"
    table.cell(dash, 0, row, "   含義", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, vix_term_hint, text_color=vix_term_color, text_size=size.tiny)
    table.merge_cells(dash, 1, row, 2, row)
    row += 1

    // 信用利差
    table.cell(dash, 0, row, " HY 信用利差", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, hy_spread_val > 0 ? str.tostring(hy_spread_val, "#.##") + "%" : "N/A", text_color=credit_color, text_size=size.small)
    table.cell(dash, 2, row, credit_status, text_color=credit_color, text_size=size.small)
    row += 1

    // ═══════════════════════════════
    // 綜合宏觀訊號
    // ═══════════════════════════════
    table.cell(dash, 0, row, " ▎綜合宏觀訊號 Macro Signal ", text_color=#00d2ff, text_size=size.small, bgcolor=color.new(#0f3460, 0))
    table.merge_cells(dash, 0, row, 2, row)
    row += 1

    table.cell(dash, 0, row, " 方向 / 強度", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, macro_label, text_color=macro_text_color, text_size=size.small)
    table.cell(dash, 2, row, str.tostring(macro_score, "#") + " / ±100", text_color=macro_text_color, text_size=size.small)
    row += 1

    table.cell(dash, 0, row, " 操作建議", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, macro_action, text_color=macro_text_color, text_size=size.small)
    table.merge_cells(dash, 1, row, 2, row)
    row += 1

    string vix_status = vix_z > 2.0 ? "🔴 恐慌" : vix_z > 1.0 ? "🟡 緊張" : vix_z > -0.5 ? "正常" : "🟢 自滿"
    table.cell(dash, 0, row, "   VIX", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, not na(vix) ? str.tostring(vix, "#.#") : "N/A", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 2, row, vix_status, text_color=vix_z > 1.0 ? color.red : vix_z > -0.5 ? color.gray : color.green, text_size=size.tiny)
    row += 1

    // ═══════════════════════════════
    // 資產配置建議
    // ═══════════════════════════════
    table.cell(dash, 0, row, " ▎資產配置建議 Allocation ", text_color=#ffd740, text_size=size.small, bgcolor=color.new(#4a3800, 0))
    table.merge_cells(dash, 0, row, 2, row)
    row += 1

    // 台股現股
    table.cell(dash, 0, row, " 台股現股", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, asset_label(tw_stock_score), text_color=asset_color(tw_stock_score), text_size=size.small)
    table.cell(dash, 2, row, str.tostring(tw_stock_score, "#.#") + " / ±3", text_color=asset_color(tw_stock_score), text_size=size.small)
    row += 1

    // 台股影響因子
    string tw_factor = (tw_oil_mod < -0.3 ? "油價⚠ " : "") + (tw_dxy_mod < -0.2 ? "匯率⚠ " : "") + (tw_rate_mod < -0.2 ? "利率⚠" : "")
    table.cell(dash, 0, row, "   風險因子", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, tw_factor != "" ? tw_factor : "─ 無特殊", text_color=tw_factor != "" ? color.orange : color.gray, text_size=size.tiny)
    table.merge_cells(dash, 1, row, 2, row)
    row += 1

    // 台指期
    table.cell(dash, 0, row, " 台指期", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, asset_label(tw_fut_score), text_color=asset_color(tw_fut_score), text_size=size.small)
    table.cell(dash, 2, row, str.tostring(tw_fut_score, "#.#") + " / ±3", text_color=asset_color(tw_fut_score), text_size=size.small)
    row += 1

    // 台指期方向建議
    string fut_dir_hint = tw_fut_score < -1.0 ? "空方操作為主" : tw_fut_score > 1.0 ? "多方操作為主" : "觀望或極輕倉"
    string fut_size_hint = sync_index >= sync_danger ? " | 部位縮小⚠" : vix_z > 1.5 ? " | 部位縮小⚠" : ""
    table.cell(dash, 0, row, "   方向/部位", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, fut_dir_hint + fut_size_hint, text_color=asset_color(tw_fut_score), text_size=size.tiny)
    table.merge_cells(dash, 1, row, 2, row)
    row += 1

    // 美股
    table.cell(dash, 0, row, " 美股", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, row, asset_label(us_stock_score), text_color=asset_color(us_stock_score), text_size=size.small)
    table.cell(dash, 2, row, str.tostring(us_stock_score, "#.#") + " / ±3", text_color=asset_color(us_stock_score), text_size=size.small)
    row += 1

    // 美股風格建議
    string us_style = real_rate_z > 1.0 ? "價值 > 成長 (利率壓估值)" : real_rate_z < -0.5 ? "成長 > 價值 (利率友善)" : "均衡配置"
    table.cell(dash, 0, row, "   風格偏好", text_color=color.new(color.silver, 30), text_size=size.tiny)
    table.cell(dash, 1, row, us_style, text_color=real_rate_z > 1.0 ? color.orange : real_rate_z < -0.5 ? color.green : color.gray, text_size=size.tiny)
    table.merge_cells(dash, 1, row, 2, row)

// ============================================================
// 警報 ALERTS
// ============================================================
alertcondition(phase_changed, title="經濟相態轉換", message="宏觀相態發生轉換！請檢查儀表板。")
alertcondition(ta.crossover(sync_index, sync_danger), title="同步性突破危險線", message="跨市場同步性突破危險線！系統性風險升高。")
alertcondition(ta.crossunder(macro_score, -50), title="宏觀轉強烈偏空", message="宏觀綜合評分跌破-50，進入強烈偏空狀態。")
alertcondition(ta.crossover(macro_score, 50), title="宏觀轉強烈偏多", message="宏觀綜合評分突破+50，進入強烈偏多狀態。")
alertcondition(oil_shock_up, title="油價急漲衝擊", message="油價20日漲幅超過30%！能源衝擊警報。")
alertcondition(phase_stability < 30, title="相態即將轉換", message="相態穩定度低於30%，可能即將發生相態轉換。")
// v1.2 新增
alertcondition(policy_shock_hawk, title="鷹派政策衝擊", message="2Y殖利率急升！市場正在重定價Fed路徑為更鷹。物價數據可能超預期。")
alertcondition(policy_shock_dove, title="鴿派政策衝擊", message="2Y殖利率急跌！市場正在重定價Fed路徑為更鴿。降息預期升溫。")
alertcondition(ta.crossover(real_rate_10y, real_rate_warn), title="實質利率突破警戒", message="10Y實質利率突破警戒線！金融條件嚴重收緊。")
alertcondition(ta.crossover(financial_tightness, 1.5), title="金融緊縮度升至嚴重", message="金融緊縮度指數突破1.5，進入嚴重緊縮區域。")
// v2.0 新增
alertcondition(growth_divergence_bear, title="銅金比背離警報", message="銅金比已下降但成長指數仍為正值！先行指標說經濟比表面更差。")
alertcondition(is_backwardation, title="VIX期限結構倒掛", message="VIX近月>遠月，市場預期恐慌不會消退。不宜抄底。")
alertcondition(false_calm, title="假性平靜警報", message="同步性回落但信用利差仍高且擴大中！表面平靜但底層壓力未解除。")
alertcondition(credit_crisis, title="信用危機警報", message="高收益債利差突破危險線！信用市場嚴重收緊。")
