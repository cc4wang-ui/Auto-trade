// =============================================================================
// TradersPost Alert Snippet — 黏到 pattern_detector_v2.pine 末端
// =============================================================================
//
// 用途：把 v2.0 偵測到的「已突破型態」訊號，轉成 TradersPost 的 webhook JSON，
//      送到 IB（透過 TradersPost bridge）自動下單。
//
// 安裝：
//   1. 把整段貼到既有 pattern_detector_v2.pine 的最後（在 //@version=5 同一份檔案裡）
//   2. 找下方標 ADAPT 的 6 行，把變數名對齊到 v2.0 內部命名（30 秒內可改完）
//   3. 編譯通過後，到 TradingView Add Alert，Condition 選這個 indicator，
//      Message 貼下方 ALERT MESSAGE TEMPLATE 區塊
//
// 不動 v2.0 任何偵測邏輯。本 snippet 只讀 v2.0 已算好的訊號 + 停損/目標。
//
// =============================================================================

// ─── Inputs ──────────────────────────────────────────────────────────────────
group_tp = "TradersPost / IB Automation"

i_tp_enabled    = input.bool(false, "Enable TradersPost alerts", group=group_tp,
                             tooltip="關掉 = 純看圖；開啟 = K 棒收盤後若達條件就發 webhook")
i_tp_watchlist  = input.string("SOFI", "Watchlist (comma-separated, blank=all)", group=group_tp,
                               tooltip="只在這些 ticker 上發 alert。例：SOFI,SOXL,TSLA。空字串=不過濾。")
i_tp_riskDollar = input.float(25.0, "Risk per trade ($)", minval=1.0, step=1.0, group=group_tp,
                              tooltip="單筆風險金額。$500 帳戶建議 $25 (5%)。TradersPost 用此值 / 停損距離 = 自動算股數。")
i_tp_minQuality = input.int(70, "Min quality score (0-100)", minval=0, maxval=100, group=group_tp,
                            tooltip="低於此分數的型態不發 alert")
i_tp_minRR      = input.float(1.5, "Min R:R ratio", minval=0.5, step=0.1, group=group_tp,
                              tooltip="低於此比值不發 alert（v2.0 已有 1.5 硬門檻，這裡是雙重保險）")
i_tp_enableLong  = input.bool(true,  "Enable long signals",  group=group_tp)
i_tp_enableShort = input.bool(false, "Enable short signals", group=group_tp,
                              tooltip="美股做空需 margin 帳戶 + 借券；$500 cash 帳戶通常用不到")

// ─── ADAPT: 對齊到 v2.0 內部變數（你 v2.0 叫什麼就改什麼） ────────────────────
// 下面 6 行是「黏合點」。把右邊的變數名換成你 v2.0 indicator 裡實際的變數。
//
//   v2.0 須提供                       本 snippet 期望
//   -----------------------------------------------
//   多單突破 bool 訊號                 → tp_isLongBreakout
//   空單突破 bool 訊號                 → tp_isShortBreakout
//   品質分 (0-100)                    → tp_quality
//   型態名稱 string                   → tp_pattern
//   停損絕對價                         → tp_stopPrice
//   目標絕對價                         → tp_targetPrice
//
// ↓↓↓ 把右邊改成 v2.0 真實變數名 ↓↓↓
tp_isLongBreakout  = is_breakout_long      // ADAPT
tp_isShortBreakout = is_breakout_short     // ADAPT
tp_quality         = quality_score         // ADAPT
tp_pattern         = pattern_name          // ADAPT (string)
tp_stopPrice       = stop_price            // ADAPT
tp_targetPrice     = target_price          // ADAPT
// ↑↑↑ 改完上面 6 行就完成黏合 ↑↑↑

// ─── Watchlist 過濾 ──────────────────────────────────────────────────────────
// 把白名單拆 array，比對當前圖表 ticker
tp_inWatchlist() =>
    if str.length(str.trim(i_tp_watchlist)) == 0
        true
    else
        list = str.split(str.replace_all(i_tp_watchlist, " ", ""), ",")
        array.includes(list, syminfo.ticker)

// ─── R:R 計算（避免 div/0） ──────────────────────────────────────────────────
tp_rrLong()  =>
    risk = close - tp_stopPrice
    risk > 0 ? (tp_targetPrice - close) / risk : 0.0

tp_rrShort() =>
    risk = tp_stopPrice - close
    risk > 0 ? (close - tp_targetPrice) / risk : 0.0

// ─── 進場條件（K 棒收盤 + 全部過濾條件 AND 起來） ─────────────────────────────
tp_longSignal  = i_tp_enabled and i_tp_enableLong  and tp_isLongBreakout  and
                 tp_inWatchlist() and barstate.isconfirmed and
                 tp_quality >= i_tp_minQuality and tp_rrLong()  >= i_tp_minRR and
                 tp_stopPrice > 0 and tp_targetPrice > 0 and tp_stopPrice < close

tp_shortSignal = i_tp_enabled and i_tp_enableShort and tp_isShortBreakout and
                 tp_inWatchlist() and barstate.isconfirmed and
                 tp_quality >= i_tp_minQuality and tp_rrShort() >= i_tp_minRR and
                 tp_stopPrice > 0 and tp_targetPrice > 0 and tp_stopPrice > close

// ─── JSON message builder ────────────────────────────────────────────────────
// 用絕對價 stopPrice / limitPrice。quantityType=risk_dollar_amount → broker 自動算股數。
// extras 帶型態 metadata 方便 TradersPost activity log 對帳。
tp_buildJson(action, stopPx, targetPx, rrVal) =>
    '{' +
      '"ticker":"' + syminfo.ticker + '",' +
      '"action":"' + action + '",' +
      '"orderType":"market",' +
      '"quantityType":"risk_dollar_amount",' +
      '"quantity":' + str.tostring(i_tp_riskDollar, "#.##") + ',' +
      '"stopLoss":{"type":"stop","stopPrice":' + str.tostring(stopPx, "#.####") + '},' +
      '"takeProfit":{"limitPrice":' + str.tostring(targetPx, "#.####") + '},' +
      '"signalPrice":' + str.tostring(close, "#.####") + ',' +
      '"timeInForce":"day",' +
      '"extras":{' +
        '"pattern":"' + tp_pattern + '",' +
        '"quality":' + str.tostring(tp_quality, "#") + ',' +
        '"rr":' + str.tostring(rrVal, "#.##") + ',' +
        '"interval":"' + timeframe.period + '"' +
      '}' +
    '}'

// ─── Alert 觸發 ──────────────────────────────────────────────────────────────
// freq_once_per_bar_close = K 棒確認收盤後才觸發一次，避免盤中跳動誤發。
if tp_longSignal
    alert(tp_buildJson("buy",  tp_stopPrice, tp_targetPrice, tp_rrLong()),
          alert.freq_once_per_bar_close)

if tp_shortSignal
    alert(tp_buildJson("sell", tp_stopPrice, tp_targetPrice, tp_rrShort()),
          alert.freq_once_per_bar_close)

// ─── 圖上視覺確認（小三角，跟既有 plot 不衝突） ──────────────────────────────
plotshape(tp_longSignal,  title="TP Long Alert",  style=shape.triangleup,
          location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny)
plotshape(tp_shortSignal, title="TP Short Alert", style=shape.triangledown,
          location=location.abovebar, color=color.new(color.red,  0), size=size.tiny)

// =============================================================================
// TradingView Alert 設定 SOP（每個 watchlist ticker 各做一次）：
//
//   1. 在該 ticker 圖表打開本 indicator
//   2. 右上 鬧鐘 icon → Add Alert
//   3. Condition：選本 indicator → 子選項選 "Any alert() function call"
//   4. Notifications → Webhook URL：勾選並貼上 TradersPost strategy 的 webhook URL
//   5. Message 欄位：填什麼都可以（會被 alert() 內部組好的 JSON 覆寫）。
//                    建議填 "{{ticker}} {{interval}} pattern alert" 作為 fallback 標籤。
//   6. Expiration：盡量設長（Premium 帳戶可 unlimited）
//   7. Save
//
// 收盤頻率：alert.freq_once_per_bar_close 已在 code 裡控制 → K 棒確認後才觸發一次。
// 不需要在對話框另外勾 "Once Per Bar Close"。
// =============================================================================
