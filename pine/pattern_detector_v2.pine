// ============================================================
// 技術型態偵測器 v2.0 | Chart Pattern Detector
//
// 核心架構：
//   Layer 1: 全域計算（ATR, 均量）
//   Layer 2: Zigzag 引擎（統一交替序列，解決 pivot 亂序）
//   Layer 3: 型態搜索（在 zigzag 上找幾何子序列）
//   Layer 4: 後處理（品質過濾 → 排序 → 截斷）
//   Layer 5: 顯示（reactive dashboard + label + alert）
//
// 雙狀態：
//   形成中 = 幾何條件成立但尚未突破
//   已突破 = 幾何 + 收盤突破觸發位
//
// 動態品質 = 對稱30% + 深度25% + 突破力/接近度20% + 量能25%
// 有效勝率 = Bulkowski 歷史基準 × (品質/100)
// ============================================================
//@version=5
indicator("技術型態偵測器 v2.0", overlay=true, max_labels_count=100, max_lines_count=100, max_bars_back=500)

// ============================================================
// LAYER 0: 參數設定
// ============================================================
group_pivot = "═══ Pivot 設定 ═══"
pivotLeft   = input.int(5, "左側確認K線", minval=2, maxval=20, group=group_pivot, tooltip="越大=越少 pivot、越可靠")
pivotRight  = input.int(3, "右側確認K線", minval=1, maxval=10, group=group_pivot, tooltip="越大=確認越慢但越準")

group_pat = "═══ 型態偵測 ═══"
tolerance    = input.float(3.0, "價格容差 %", minval=0.5, maxval=8.0, step=0.5, group=group_pat, tooltip="兩個價位差距在此%內視為「相似」")
volMultiple  = input.float(1.2, "量能確認倍數(T2)", minval=1.0, maxval=3.0, step=0.1, group=group_pat, tooltip="Tier 2 突破量 ≥ 均量 × 此值")
volAvgLen    = input.int(20, "均量計算期", minval=5, maxval=50, group=group_pat)
maxPatBars   = input.int(200, "型態最大跨度(K線)", minval=30, maxval=500, group=group_pat, tooltip="超過此跨度視為過期")

group_filter = "═══ 噪音過濾 ═══"
minPatBars   = input.int(5, "型態最小跨度(K線)", minval=2, maxval=60, group=group_filter)
minHeightATR = input.float(0.5, "型態最小高度(×ATR)", minval=0.1, maxval=5.0, step=0.1, group=group_filter)
minQuality   = input.int(0, "最低品質分", minval=0, maxval=100, group=group_filter, tooltip="設 0 = 全部顯示（debug）")
minRR        = input.float(1.5, "最低 R:R 比", minval=1.0, maxval=5.0, step=0.1, group=group_filter, tooltip="目標價自動調整確保 R:R ≥ 此值。低於 1.0 的型態不顯示")
cooldownBars = input.int(20, "冷卻期(K線)", minval=5, maxval=100, group=group_filter)
maxSignals   = input.int(3, "最大同時顯示數", minval=1, maxval=5, group=group_filter)

group_t1 = "═══ Tier 1 (≥80%) ═══"
en_invHS   = input.bool(true, "反轉頭肩底 89%", group=group_t1)
en_dblBot  = input.bool(true, "雙重底 88%", group=group_t1)
en_triBot  = input.bool(true, "三重底 87%", group=group_t1)
en_descTri = input.bool(true, "下降三角 87%", group=group_t1)
en_rectTop = input.bool(true, "矩形頂 85%", group=group_t1)
en_ascTri  = input.bool(true, "上升三角 83%", group=group_t1)
en_hsTop   = input.bool(true, "頭肩頂 81%", group=group_t1)

group_t2 = "═══ Tier 2 (70-79% 需量確認) ═══"
en_cup      = input.bool(true, "杯柄 79%", group=group_t2)
en_bullFlag = input.bool(true, "牛旗 78%", group=group_t2)
en_symTri   = input.bool(true, "對稱三角 76%", group=group_t2)
en_dblTop   = input.bool(true, "雙重頂 73%", group=group_t2)
en_fallWdg  = input.bool(true, "下降楔形 72%", group=group_t2)

group_disp = "═══ 顯示 ═══"
showTable  = input.bool(true, "顯示儀表板", group=group_disp)
showLabels = input.bool(true, "顯示圖表標籤", group=group_disp)
showLines  = input.bool(true, "顯示關鍵價位線", group=group_disp)
showZZ     = input.bool(true, "顯示 Zigzag 節點", group=group_disp, tooltip="圖表上標記 pivot 位置，確認偵測正常")
tablePos   = input.string("右上", "儀表板位置", options=["左上","右上","左下","右下"], group=group_disp)

// ============================================================
// LAYER 1: 全域計算（在工具函數之前）
// ============================================================
float avgVol = ta.sma(volume, volAvgLen)
float atr14  = ta.atr(14)
bool  volOK  = not na(avgVol) and volume >= avgVol * volMultiple

// ============================================================
// 工具函數
// ============================================================
safe_div(float a, float b) =>
    b != 0 and not na(b) ? a / b : 0.0

isSimilar(float a, float b) =>
    not na(a) and not na(b) and math.abs(a - b) / math.max(math.abs(a), math.abs(b)) * 100 <= tolerance

isRecent(int pivotBar) =>
    bar_index - pivotBar <= maxPatBars

// ─── 品質因子（校準後，見 pitfalls P2-1）───
qSym(float a, float b) =>
    float diff = math.abs(a - b) / math.max(math.abs(a), math.abs(b)) * 100
    math.max(0.0, 1.0 - diff / (tolerance * 1.5))

qDepth(float height) =>
    math.min(safe_div(height, math.max(atr14, 0.01)), 1.0)

qBreak(float cl, float trigger, bool isBull) =>
    float dist = isBull ? cl - trigger : trigger - cl
    math.max(0.0, math.min(safe_div(dist, math.max(atr14 * 0.3, 0.01)), 1.0))

qProx(float cl, float trigger, bool isBull) =>
    float dist = isBull ? trigger - cl : cl - trigger
    dist <= 0 ? 1.0 : math.max(0.0, 1.0 - safe_div(dist, math.max(atr14, 0.01)))

qVol() =>
    not na(avgVol) and avgVol > 0 ? math.min(safe_div(volume, avgVol * 1.2), 1.0) : 0.5

calcQ(float sym, float depth, float bk, float vol) =>
    math.round(math.max(0.0, math.min(100.0, sym * 30 + depth * 25 + bk * 20 + vol * 25)))

effWR(float baseWR, float q) =>
    math.round(baseWR * q / 100)

// 確保目標價給出 R:R ≥ minRR。如果 measured move 不夠，拉到 minRR。
adjTgt(float entry, float stop, float rawTgt, bool isBull) =>
    float risk = math.abs(entry - stop)
    float minReward = risk * minRR
    if isBull
        math.max(rawTgt, entry + minReward)
    else
        math.min(rawTgt, entry - minReward)

// ============================================================
// LAYER 2: Zigzag 引擎
// ============================================================
float rawPH = ta.pivothigh(high, pivotLeft, pivotRight)
float rawPL = ta.pivotlow(low, pivotLeft, pivotRight)

var zzP = array.new_float(0)   // 價格
var zzB = array.new_int(0)     // K線位置
var zzD = array.new_int(0)     // 方向 1=低 -1=高

// 加入新 pivot low → 保證交替
if not na(rawPL)
    int bIdx = bar_index - pivotRight
    bool isEmpty = array.size(zzD) == 0
    bool shouldInsert = isEmpty
    if not isEmpty
        shouldInsert := array.get(zzD, 0) != 1
    if shouldInsert
        array.unshift(zzP, rawPL)
        array.unshift(zzB, bIdx)
        array.unshift(zzD, 1)
    else
        if not isEmpty and rawPL < array.get(zzP, 0)
            array.set(zzP, 0, rawPL)
            array.set(zzB, 0, bIdx)

// 加入新 pivot high → 保證交替
if not na(rawPH)
    int bIdx = bar_index - pivotRight
    bool isEmpty = array.size(zzD) == 0
    bool shouldInsert = isEmpty
    if not isEmpty
        shouldInsert := array.get(zzD, 0) != -1
    if shouldInsert
        array.unshift(zzP, rawPH)
        array.unshift(zzB, bIdx)
        array.unshift(zzD, -1)
    else
        if not isEmpty and rawPH > array.get(zzP, 0)
            array.set(zzP, 0, rawPH)
            array.set(zzB, 0, bIdx)

// 限制大小
while array.size(zzP) > 20
    array.pop(zzP)
    array.pop(zzB)
    array.pop(zzD)

int zzSz = array.size(zzP)

// Zigzag 可視化
plotshape(showZZ and not na(rawPH), "ZZ High", shape.triangledown, location.abovebar, color=color.new(color.red, 40), size=size.tiny)
plotshape(showZZ and not na(rawPL), "ZZ Low", shape.triangleup, location.belowbar, color=color.new(color.green, 40), size=size.tiny)

// ============================================================
// LAYER 3: 結果收集（addResult 只收集，不過濾 — P3-3）
// ============================================================
var resName  = array.new_string(0)
var resTier  = array.new_int(0)
var resDir   = array.new_string(0)
var resState = array.new_string(0)  // "形成中" or "已突破"
var resEntry = array.new_float(0)
var resStop  = array.new_float(0)
var resTgt   = array.new_float(0)
var resQ     = array.new_float(0)   // 品質 0-100
var resBWR   = array.new_float(0)   // 歷史基準
var resEWR   = array.new_float(0)   // 有效WR
var resSpan  = array.new_int(0)     // 跨度(K線)
var resHt    = array.new_float(0)   // 高度

array.clear(resName),  array.clear(resTier), array.clear(resDir),   array.clear(resState)
array.clear(resEntry), array.clear(resStop), array.clear(resTgt)
array.clear(resQ),     array.clear(resBWR),  array.clear(resEWR)
array.clear(resSpan),  array.clear(resHt)

addR(string nm, int tier, string dir, string st, float ent, float stp, float tgt, float q, float bwr, int span, float ht) =>
    // 自動調整目標價確保 R:R ≥ minRR
    bool isBull = str.contains(dir, "▲")
    float adjT = not na(ent) and not na(stp) and not na(tgt) ? adjTgt(ent, stp, tgt, isBull) : tgt
    array.push(resName, nm),    array.push(resTier, tier),  array.push(resDir, dir),    array.push(resState, st)
    array.push(resEntry, ent),  array.push(resStop, stp),   array.push(resTgt, adjT)
    array.push(resQ, q),        array.push(resBWR, bwr),    array.push(resEWR, effWR(bwr, q))
    array.push(resSpan, span),  array.push(resHt, ht)

// ============================================================
// 型態搜索：在 zigzag 上找幾何子序列
//
// 命名慣例：
//   i0 = zigzag 最近匹配起點的 index
//   p0,p1,p2... = 從 i0 開始的 zigzag 節點價格
//   b0,b1,b2... = 對應 K 線位置
// ============================================================

// ─── 搜索輔助：找第一個方向=dir 的 zigzag index ───
firstOf(int dir) =>
    int r = -1
    if zzSz > 0
        r := array.get(zzD, 0) == dir ? 0 : (zzSz > 1 ? 1 : -1)
    r

int iLow  = firstOf(1)     // 最近一個低點的 index
int iHigh = firstOf(-1)    // 最近一個高點的 index

// ─── 1. 雙重底 Double Bottom (88%) ───
// Zigzag: L0 - H0 - L1 (3 nodes starting from low)
if en_dblBot and iLow >= 0 and iLow + 2 < zzSz
    int i = iLow
    float L0 = array.get(zzP, i),     float H0 = array.get(zzP, i+1),   float L1 = array.get(zzP, i+2)
    int   b0 = array.get(zzB, i),     int   b2 = array.get(zzB, i+2)
    if isRecent(b2) and isSimilar(L0, L1) and H0 > L0 and H0 > L1
        float ht = H0 - math.min(L0, L1)
        float stp = math.min(L0, L1) - atr14 * 0.5
        float tgt = H0 + ht
        int span = b0 - b2
        bool brk = close > H0
        bool t2vol = true  // T1 不需量確認
        float qs = qSym(L0, L1),  float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, H0, true) : qProx(close, H0, true)
        float q = calcQ(qs, qd, qb, qv)
        string st = brk ? "已突破" : "形成中"
        addR("雙重底", 1, "▲ 做多", st, H0, stp, tgt, q, 88, span, ht)

// ─── 2. 反轉頭肩底 Inv H&S (89%) ───
// Zigzag: L0(右肩) - H0 - L1(頭) - H1 - L2(左肩) (5 nodes from low)
if en_invHS and iLow >= 0 and iLow + 4 < zzSz
    int i = iLow
    float L0 = array.get(zzP, i),     float H0 = array.get(zzP, i+1)
    float L1 = array.get(zzP, i+2),   float H1 = array.get(zzP, i+3)
    float L2 = array.get(zzP, i+4)
    int   b0 = array.get(zzB, i),     int   b4 = array.get(zzB, i+4)
    bool headOK = L1 < L0 and L1 < L2
    bool symOK = isSimilar(L0, L2)
    if isRecent(b4) and headOK and symOK
        float neck = math.min(H0, H1)
        float ht = neck - L1
        float stp = L1 - atr14 * 0.5
        float tgt = neck + ht
        int span = b0 - b4
        bool brk = close > neck
        float qs_sh = qSym(L0, L2)
        float headProm = math.min(safe_div(math.min(L0, L2) - L1, math.max(atr14, 0.01)), 1.0)
        float qs = qs_sh * 0.5 + headProm * 0.5
        float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, neck, true) : qProx(close, neck, true)
        float q = calcQ(qs, qd, qb, qv)
        addR("反轉頭肩底", 1, "▲ 做多", brk ? "已突破" : "形成中", neck, stp, tgt, q, 89, span, ht)

// ─── 3. 三重底 Triple Bottom (87%) ───
// Zigzag: L0 - H0 - L1 - H1 - L2 (5 nodes from low)
if en_triBot and iLow >= 0 and iLow + 4 < zzSz
    int i = iLow
    float L0 = array.get(zzP, i),     float H0 = array.get(zzP, i+1)
    float L1 = array.get(zzP, i+2),   float H1 = array.get(zzP, i+3)
    float L2 = array.get(zzP, i+4)
    int   b0 = array.get(zzB, i),     int   b4 = array.get(zzB, i+4)
    if isRecent(b4) and isSimilar(L0, L1) and isSimilar(L1, L2)
        float neck = math.max(H0, H1)
        float lowest = math.min(L0, math.min(L1, L2))
        float ht = neck - lowest
        float stp = lowest - atr14 * 0.5
        float tgt = neck + ht
        int span = b0 - b4
        bool brk = close > neck
        float qs = (qSym(L0, L1) + qSym(L1, L2)) / 2.0
        float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, neck, true) : qProx(close, neck, true)
        addR("三重底", 1, "▲ 做多", brk ? "已突破" : "形成中", neck, stp, tgt, calcQ(qs, qd, qb, qv), 87, span, ht)

// ─── 4. 下降三角 Descending Triangle (87%) ───
// Zigzag: H0 - L0 - H1 - L1 (4 nodes from high), H's下降 L's平
if en_descTri and iHigh >= 0 and iHigh + 3 < zzSz
    int i = iHigh
    float H0 = array.get(zzP, i),     float L0 = array.get(zzP, i+1)
    float H1 = array.get(zzP, i+2),   float L1 = array.get(zzP, i+3)
    int   b0 = array.get(zzB, i),     int   b3 = array.get(zzB, i+3)
    if isRecent(b3) and isSimilar(L0, L1) and H0 < H1 and H0 > L0
        float support = math.min(L0, L1)
        float ht = H1 - support
        float stp = H0 + atr14 * 0.5
        float tgt = support - ht
        int span = b0 - b3
        bool brk = close < support
        float qs = qSym(L0, L1),  float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, support, false) : qProx(close, support, false)
        addR("下降三角", 1, "▼ 做空", brk ? "已突破" : "形成中", support, stp, tgt, calcQ(qs, qd, qb, qv), 87, span, ht)

// ─── 5. 矩形頂 Rectangle Top (85%) ───
// Zigzag: 4 nodes, H's平 L's平
if en_rectTop and zzSz >= 4
    int i = 0
    float p0 = array.get(zzP, i),   float p1 = array.get(zzP, i+1)
    float p2 = array.get(zzP, i+2), float p3 = array.get(zzP, i+3)
    int   b0 = array.get(zzB, i),   int   b3 = array.get(zzB, i+3)
    // 找出哪些是 high 哪些是 low
    int d0 = array.get(zzD, i)
    float rH0 = d0 == -1 ? p0 : p1,  float rH1 = d0 == -1 ? p2 : p3
    float rL0 = d0 == 1  ? p0 : p1,  float rL1 = d0 == 1  ? p2 : p3
    if isRecent(b3) and isSimilar(rH0, rH1) and isSimilar(rL0, rL1) and rH0 > rL0
        float res = math.max(rH0, rH1),  float sup = math.min(rL0, rL1)
        float ht = res - sup
        int span = b0 - b3
        float qs = (qSym(rH0, rH1) + qSym(rL0, rL1)) / 2.0
        float qd = qDepth(ht),  float qv = qVol()
        if close > res
            float qb = qBreak(close, res, true)
            addR("矩形頂突破", 1, "▲ 做多", "已突破", res, sup - atr14*0.3, res + ht, calcQ(qs, qd, qb, qv), 85, span, ht)
        else if close < sup
            float qb = qBreak(close, sup, false)
            addR("矩形頂跌破", 1, "▼ 做空", "已突破", sup, res + atr14*0.3, sup - ht, calcQ(qs, qd, qb, qv), 85, span, ht)
        else
            float qbUp = qProx(close, res, true)
            float qbDn = qProx(close, sup, false)
            float qb = math.max(qbUp, qbDn)
            string dir = qbUp > qbDn ? "▲ 待突破" : "▼ 待跌破"
            float trig = qbUp > qbDn ? res : sup
            addR("矩形", 1, dir, "形成中", trig, na, na, calcQ(qs, qd, qb, qv), 85, span, ht)

// ─── 6. 上升三角 Ascending Triangle (83%) ───
// Zigzag: L0 - H0 - L1 - H1 (4 nodes from low), L's上升 H's平
if en_ascTri and iLow >= 0 and iLow + 3 < zzSz
    int i = iLow
    float L0 = array.get(zzP, i),     float H0 = array.get(zzP, i+1)
    float L1 = array.get(zzP, i+2),   float H1 = array.get(zzP, i+3)
    int   b0 = array.get(zzB, i),     int   b3 = array.get(zzB, i+3)
    if isRecent(b3) and isSimilar(H0, H1) and L0 > L1 and H0 > L0
        float res = math.max(H0, H1)
        float ht = res - L1
        float stp = L0 - atr14 * 0.5
        float tgt = res + ht
        int span = b0 - b3
        bool brk = close > res
        float qs = qSym(H0, H1),  float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, res, true) : qProx(close, res, true)
        addR("上升三角", 1, "▲ 做多", brk ? "已突破" : "形成中", res, stp, tgt, calcQ(qs, qd, qb, qv), 83, span, ht)

// ─── 7. 頭肩頂 H&S Top (81%) ───
// Zigzag: H0(右肩) - L0 - H1(頭) - L1 - H2(左肩) (5 from high)
if en_hsTop and iHigh >= 0 and iHigh + 4 < zzSz
    int i = iHigh
    float H0 = array.get(zzP, i),     float L0 = array.get(zzP, i+1)
    float H1 = array.get(zzP, i+2),   float L1 = array.get(zzP, i+3)
    float H2 = array.get(zzP, i+4)
    int   b0 = array.get(zzB, i),     int   b4 = array.get(zzB, i+4)
    bool headOK = H1 > H0 and H1 > H2
    bool symOK = isSimilar(H0, H2)
    if isRecent(b4) and headOK and symOK
        float neck = math.max(L0, L1)
        float ht = H1 - neck
        float stp = H1 + atr14 * 0.5
        float tgt = neck - ht
        int span = b0 - b4
        bool brk = close < neck
        float qs_sh = qSym(H0, H2)
        float headProm = math.min(safe_div(H1 - math.max(H0, H2), math.max(atr14, 0.01)), 1.0)
        float qs = qs_sh * 0.5 + headProm * 0.5
        float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, neck, false) : qProx(close, neck, false)
        addR("頭肩頂", 1, "▼ 做空", brk ? "已突破" : "形成中", neck, stp, tgt, calcQ(qs, qd, qb, qv), 81, span, ht)

// ─── 8. 杯柄 Cup & Handle (79%) ───
// Zigzag: H0(rim右) - L0(柄底) - H1(rim中) - L1(杯底) - H2(rim左) (5 from high)
if en_cup and iHigh >= 0 and iHigh + 4 < zzSz
    int i = iHigh
    float H0 = array.get(zzP, i),     float L0 = array.get(zzP, i+1)
    float H1 = array.get(zzP, i+2),   float L1 = array.get(zzP, i+3)
    float H2 = array.get(zzP, i+4)
    int   b0 = array.get(zzB, i),     int   b4 = array.get(zzB, i+4)
    bool rimOK = isSimilar(H1, H2)
    bool cupDeep = L1 < H1 and L1 < H2
    bool handleShallow = L0 > L1 and (H0 - L0) < (H1 - L1) * 0.5
    if isRecent(b4) and rimOK and cupDeep and handleShallow
        float rim = math.max(H1, H2)
        float ht = rim - L1
        float stp = L0 - atr14 * 0.5
        float tgt = rim + ht
        int span = b0 - b4
        bool brk = close > rim and volOK
        float qs_r = qSym(H1, H2)
        float hRatio = 1.0 - math.min(safe_div(H0 - L0, math.max(H1 - L1, 0.01)), 1.0)
        float qs = qs_r * 0.6 + hRatio * 0.4
        float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, rim, true) : qProx(close, rim, true)
        addR("杯柄", 2, "▲ 做多", brk ? "已突破" : "形成中", rim, stp, tgt, calcQ(qs, qd, qb, qv), 79, span, ht)

// ─── 9. 牛旗 Bull Flag (78%) ───
// Zigzag: L0(旗底) - H0(旗桿頂) - L1(旗桿底) (3 from low)
// 旗桿 = H0 - L1 要大，旗面 = H0 - L0 要小
if en_bullFlag and iLow >= 0 and iLow + 2 < zzSz
    int i = iLow
    float L0 = array.get(zzP, i),     float H0 = array.get(zzP, i+1)
    float L1 = array.get(zzP, i+2)
    int   b0 = array.get(zzB, i),     int   b2 = array.get(zzB, i+2)
    float pole = H0 - L1
    float flag = H0 - L0
    bool poleStrong = safe_div(pole, math.max(L1, 0.01)) * 100 > 3
    bool flagTight = flag < pole * 0.5 and L0 > L1
    if isRecent(b2) and poleStrong and flagTight and pole > 0
        float stp = L0 - atr14 * 0.5
        float tgt = H0 + pole * 0.7
        int span = b0 - b2
        bool brk = close > H0 and volOK
        float tightness = 1.0 - math.min(safe_div(flag, math.max(pole, 0.01)), 1.0)
        float pStr = math.min(safe_div(pole, math.max(L1, 0.01)) * 100 / 10.0, 1.0)
        float qs = tightness * 0.5 + pStr * 0.5
        float qd = qDepth(pole),  float qv = qVol()
        float qb = brk ? qBreak(close, H0, true) : qProx(close, H0, true)
        addR("牛旗", 2, "▲ 做多", brk ? "已突破" : "形成中", H0, stp, tgt, calcQ(qs, qd, qb, qv), 78, span, pole)

// ─── 10. 對稱三角 Symmetrical Triangle (76%) ───
// 4 nodes: H's 下降, L's 上升
if en_symTri and zzSz >= 4
    int i = 0
    float p0 = array.get(zzP, i),   float p1 = array.get(zzP, i+1)
    float p2 = array.get(zzP, i+2), float p3 = array.get(zzP, i+3)
    int   b0 = array.get(zzB, i),   int   b3 = array.get(zzB, i+3)
    int d0 = array.get(zzD, i)
    float sH0 = d0 == -1 ? p0 : p1,  float sH1 = d0 == -1 ? p2 : p3
    float sL0 = d0 == 1  ? p0 : p1,  float sL1 = d0 == 1  ? p2 : p3
    bool lowerH = sH0 < sH1
    bool higherL = sL0 > sL1
    if isRecent(b3) and lowerH and higherL and sH0 > sL0
        float ht = sH1 - sL1
        int span = b0 - b3
        float topShrink = sH1 - sH0,  float botShrink = sL0 - sL1
        float convSym = 1.0 - math.abs(topShrink - botShrink) / math.max(topShrink + botShrink, 0.01)
        float qd = qDepth(ht),  float qv = qVol()
        if close > sH0 and volOK
            addR("對稱三角▲", 2, "▲ 做多", "已突破", sH0, sL0 - atr14*0.5, sH0 + ht*0.6, calcQ(convSym, qd, qBreak(close, sH0, true), qv), 76, span, ht)
        else if close < sL0 and volOK
            addR("對稱三角▼", 2, "▼ 做空", "已突破", sL0, sH0 + atr14*0.5, sL0 - ht*0.6, calcQ(convSym, qd, qBreak(close, sL0, false), qv), 76, span, ht)
        else
            float qb = math.max(qProx(close, sH0, true), qProx(close, sL0, false))
            addR("對稱三角", 2, "─ 待突破", "形成中", close > (sH0+sL0)/2 ? sH0 : sL0, na, na, calcQ(convSym, qd, qb, qv), 76, span, ht)

// ─── 11. 雙重頂 Double Top (73%) ───
// Zigzag: H0 - L0 - H1 (3 from high)
if en_dblTop and iHigh >= 0 and iHigh + 2 < zzSz
    int i = iHigh
    float H0 = array.get(zzP, i),     float L0 = array.get(zzP, i+1)
    float H1 = array.get(zzP, i+2)
    int   b0 = array.get(zzB, i),     int   b2 = array.get(zzB, i+2)
    if isRecent(b2) and isSimilar(H0, H1) and L0 < H0 and L0 < H1
        float ht = math.max(H0, H1) - L0
        float stp = math.max(H0, H1) + atr14 * 0.5
        float tgt = L0 - ht
        int span = b0 - b2
        bool brk = close < L0 and volOK
        float qs = qSym(H0, H1),  float qd = qDepth(ht),  float qv = qVol()
        float qb = brk ? qBreak(close, L0, false) : qProx(close, L0, false)
        addR("雙重頂", 2, "▼ 做空", brk ? "已突破" : "形成中", L0, stp, tgt, calcQ(qs, qd, qb, qv), 73, span, ht)

// ─── 12. 下降楔形 Falling Wedge (72%) ───
// 4 nodes: H's下降 L's下降，但收斂
if en_fallWdg and zzSz >= 4
    int i = 0
    float p0 = array.get(zzP, i),   float p1 = array.get(zzP, i+1)
    float p2 = array.get(zzP, i+2), float p3 = array.get(zzP, i+3)
    int   b0 = array.get(zzB, i),   int   b3 = array.get(zzB, i+3)
    int d0 = array.get(zzD, i)
    float wH0 = d0 == -1 ? p0 : p1,  float wH1 = d0 == -1 ? p2 : p3
    float wL0 = d0 == 1  ? p0 : p1,  float wL1 = d0 == 1  ? p2 : p3
    bool bothFall = wH0 < wH1 and wL0 < wL1
    bool converge = (wH1 - wL1) > (wH0 - wL0)
    if isRecent(b3) and bothFall and converge and wH0 > wL0
        float ht = wH1 - wL1
        int span = b0 - b3
        float widthR = safe_div(wH0 - wL0, math.max(wH1 - wL1, 0.01))
        float convS = 1.0 - math.min(widthR, 1.0)
        float qd = qDepth(ht),  float qv = qVol()
        bool brk = close > wH0 and volOK
        float qb = brk ? qBreak(close, wH0, true) : qProx(close, wH0, true)
        addR("下降楔形", 2, "▲ 做多", brk ? "已突破" : "形成中", wH0, wL0 - atr14*0.5, wH0 + ht*0.5, calcQ(convS, qd, qb, qv), 72, span, ht)

// ============================================================
// LAYER 4: 後處理（過濾 → 排序 → 截斷）
// ============================================================
int rawCount = array.size(resName)

// 冷卻期追蹤
var cdNames = array.new_string(0)
var cdBars  = array.new_int(0)

// Step 1: 過濾
if rawCount > 0
    for i = rawCount - 1 to 0
        int sp = array.get(resSpan, i)
        float ht = array.get(resHt, i)
        float q = array.get(resQ, i)
        string nm = array.get(resName, i)
        bool spanOK = sp >= minPatBars
        bool htOK = not na(atr14) ? ht >= atr14 * minHeightATR : true
        bool qOK = q >= minQuality
        // 冷卻檢查
        bool coolOK = true
        if array.size(cdNames) > 0
            for j = 0 to array.size(cdNames) - 1
                if array.get(cdNames, j) == nm and bar_index - array.get(cdBars, j) < cooldownBars
                    coolOK := false
                    break
        // R:R 檢查（形成中但 entry/stop/tgt 有值的也檢查）
        float ent_i = array.get(resEntry, i)
        float stp_i = array.get(resStop, i)
        float tgt_i = array.get(resTgt, i)
        float rr_i = not na(ent_i) and not na(stp_i) and not na(tgt_i) and math.abs(ent_i - stp_i) > 0 ? safe_div(math.abs(tgt_i - ent_i), math.abs(ent_i - stp_i)) : 999.0
        bool rrOK = rr_i >= 1.0
        if not (spanOK and htOK and qOK and coolOK and rrOK)
            array.remove(resName, i),  array.remove(resTier, i),  array.remove(resDir, i),  array.remove(resState, i)
            array.remove(resEntry, i), array.remove(resStop, i),  array.remove(resTgt, i)
            array.remove(resQ, i),     array.remove(resBWR, i),   array.remove(resEWR, i)
            array.remove(resSpan, i),  array.remove(resHt, i)

// 設冷卻
int filtCount = array.size(resName)
if filtCount > 0
    for i = 0 to filtCount - 1
        string nm = array.get(resName, i)
        if array.get(resState, i) == "已突破"
            bool found = false
            if array.size(cdNames) > 0
                for j = 0 to array.size(cdNames) - 1
                    if array.get(cdNames, j) == nm
                        array.set(cdBars, j, bar_index)
                        found := true
                        break
            if not found
                array.push(cdNames, nm)
                array.push(cdBars, bar_index)

// Step 2: 排序（T1優先 → 有效WR高的前面）
if filtCount > 1
    for i = 0 to filtCount - 2
        for j = 0 to filtCount - i - 2
            float sJ  = -array.get(resTier, j) * 1000 + array.get(resEWR, j)
            float sJ1 = -array.get(resTier, j+1) * 1000 + array.get(resEWR, j+1)
            if sJ1 > sJ
                // swap all parallel arrays
                string ts = array.get(resName, j),  array.set(resName, j, array.get(resName, j+1)),  array.set(resName, j+1, ts)
                ts := array.get(resDir, j),   array.set(resDir, j, array.get(resDir, j+1)),     array.set(resDir, j+1, ts)
                ts := array.get(resState, j), array.set(resState, j, array.get(resState, j+1)), array.set(resState, j+1, ts)
                int ti = array.get(resTier, j),  array.set(resTier, j, array.get(resTier, j+1)),  array.set(resTier, j+1, ti)
                float tf = array.get(resEntry, j), array.set(resEntry, j, array.get(resEntry, j+1)), array.set(resEntry, j+1, tf)
                tf := array.get(resStop, j),  array.set(resStop, j, array.get(resStop, j+1)),  array.set(resStop, j+1, tf)
                tf := array.get(resTgt, j),   array.set(resTgt, j, array.get(resTgt, j+1)),   array.set(resTgt, j+1, tf)
                tf := array.get(resQ, j),     array.set(resQ, j, array.get(resQ, j+1)),       array.set(resQ, j+1, tf)
                tf := array.get(resBWR, j),   array.set(resBWR, j, array.get(resBWR, j+1)),   array.set(resBWR, j+1, tf)
                tf := array.get(resEWR, j),   array.set(resEWR, j, array.get(resEWR, j+1)),   array.set(resEWR, j+1, tf)

// Step 3: 截斷
while array.size(resName) > maxSignals
    array.pop(resName),  array.pop(resTier),  array.pop(resDir),  array.pop(resState)
    array.pop(resEntry), array.pop(resStop),  array.pop(resTgt)
    array.pop(resQ),     array.pop(resBWR),   array.pop(resEWR)
    if array.size(resSpan) > maxSignals
        array.pop(resSpan), array.pop(resHt)

// ============================================================
// LAYER 5: 顯示
// ============================================================
int resultCount = array.size(resName)

// ─── Label + Line（reactive: var + delete/recreate）───
var label sigLbl = na
var line  lnEntry = na
var line  lnStop  = na
var line  lnTgt   = na
label.delete(sigLbl),  line.delete(lnEntry),  line.delete(lnStop),  line.delete(lnTgt)
sigLbl := na,  lnEntry := na,  lnStop := na,  lnTgt := na

if showLabels and resultCount > 0
    string nm  = array.get(resName, 0)
    string dr  = array.get(resDir, 0)
    string st  = array.get(resState, 0)
    float q    = array.get(resQ, 0)
    float ewr  = array.get(resEWR, 0)
    float tgt  = array.get(resTgt, 0)
    bool bull  = str.contains(dr, "▲")
    string txt = nm + " [" + st + "]\n品質:" + str.tostring(q, "#") + " WR:" + str.tostring(ewr, "#") + "%"
    color lc   = st == "已突破" ? (bull ? color.new(#1D9E75, 10) : color.new(#E24B4A, 10)) : color.new(color.gray, 30)
    sigLbl := label.new(bar_index, bull ? low - atr14 : high + atr14, txt, color=lc, textcolor=color.white, style=bull ? label.style_label_up : label.style_label_down, size=size.small)

if showLines and resultCount > 0
    if array.get(resState, 0) == "已突破"
        float e = array.get(resEntry, 0),  float s = array.get(resStop, 0),  float t = array.get(resTgt, 0)
        if not na(e)
            lnEntry := line.new(bar_index - 15, e, bar_index + 5, e, color=color.new(color.white, 30), width=1, style=line.style_dashed)
        if not na(s)
            lnStop := line.new(bar_index - 15, s, bar_index + 5, s, color=color.new(color.red, 30), width=1, style=line.style_dotted)
        if not na(t)
            lnTgt := line.new(bar_index - 15, t, bar_index + 5, t, color=color.new(color.green, 30), width=1, style=line.style_dotted)

// ─── Dashboard ───
get_tpos(string p) => p == "左上" ? position.top_left : p == "右上" ? position.top_right : p == "左下" ? position.bottom_left : position.bottom_right
var table dash = table.new(get_tpos(tablePos), 10, 14, bgcolor=color.new(#1a1a2e, 0), border_width=1, border_color=color.new(color.gray, 70))

if barstate.islast and showTable
    int row = 0
    table.cell(dash, 0, row, "  型態偵測器 v2.0  ", text_color=color.white, text_size=size.normal, bgcolor=color.new(#16213e, 0))
    table.merge_cells(dash, 0, row, 9, row)
    row += 1

    string[] hdr = array.from("型態", "Tier", "狀態", "方向", "品質", "有效WR", "進場", "停損", "目標", "R:R")
    for c = 0 to 9
        table.cell(dash, c, row, array.get(hdr, c), text_color=#00d2ff, text_size=size.tiny, bgcolor=color.new(#0f3460, 0))
    row += 1

    if resultCount == 0
        table.cell(dash, 0, row, " 目前無偵測到型態", text_color=color.gray, text_size=size.small)
        table.merge_cells(dash, 0, row, 9, row)
    else
        for i = 0 to math.min(resultCount - 1, 4)
            string nm   = array.get(resName, i)
            int tier    = array.get(resTier, i)
            string st   = array.get(resState, i)
            string dr   = array.get(resDir, i)
            float q     = array.get(resQ, i)
            float ewr   = array.get(resEWR, i)
            float ent   = array.get(resEntry, i)
            float stp   = array.get(resStop, i)
            float tgt   = array.get(resTgt, i)
            float rr    = not na(ent) and not na(stp) and not na(tgt) ? safe_div(math.abs(tgt - ent), math.abs(ent - stp)) : 0
            bool bull   = str.contains(dr, "▲")
            color stCol = st == "已突破" ? (bull ? color.green : color.red) : color.gray
            color qCol  = q >= 70 ? color.green : q >= 40 ? color.yellow : color.red
            string qLbl = q >= 70 ? " 優" : q >= 50 ? " 良" : q >= 30 ? " 弱" : " 差"
            color eCol  = ewr >= 60 ? color.green : ewr >= 40 ? color.yellow : color.red

            table.cell(dash, 0, row, " " + nm, text_color=color.white, text_size=size.tiny)
            table.cell(dash, 1, row, tier == 1 ? "T1" : "T2", text_color=tier == 1 ? color.lime : color.yellow, text_size=size.tiny)
            table.cell(dash, 2, row, st, text_color=stCol, text_size=size.tiny)
            table.cell(dash, 3, row, dr, text_color=bull ? color.green : str.contains(dr, "▼") ? color.red : color.gray, text_size=size.tiny)
            table.cell(dash, 4, row, str.tostring(q, "#") + qLbl, text_color=qCol, text_size=size.tiny)
            table.cell(dash, 5, row, str.tostring(ewr, "#") + "%", text_color=eCol, text_size=size.tiny)
            table.cell(dash, 6, row, not na(ent) ? str.tostring(ent, "#.##") : "─", text_color=color.silver, text_size=size.tiny)
            table.cell(dash, 7, row, not na(stp) ? str.tostring(stp, "#.##") : "─", text_color=color.red, text_size=size.tiny)
            table.cell(dash, 8, row, not na(tgt) ? str.tostring(tgt, "#.##") : "─", text_color=color.green, text_size=size.tiny)
            table.cell(dash, 9, row, rr > 0 ? str.tostring(rr, "#.#") + "x" : "─", text_color=rr >= 2 ? color.green : rr >= 1 ? color.yellow : color.gray, text_size=size.tiny)
            row += 1

    row += 1
    table.cell(dash, 0, row, "品質=對稱30+深度25+突破/接近20+量能25 | WR=基準×品質", text_color=color.new(color.silver, 40), text_size=size.tiny)
    table.merge_cells(dash, 0, row, 9, row)
    row += 1
    string dbg = "ZZ=" + str.tostring(zzSz) + " | 偵測=" + str.tostring(rawCount) + "→過濾=" + str.tostring(filtCount) + "→顯示=" + str.tostring(resultCount)
    table.cell(dash, 0, row, dbg, text_color=color.new(color.yellow, 30), text_size=size.tiny)
    table.merge_cells(dash, 0, row, 9, row)

// ─── Alert（只在「已突破」時觸發）───
bool anyConfirmed = false
if resultCount > 0
    for i = 0 to resultCount - 1
        if array.get(resState, i) == "已突破"
            anyConfirmed := true
            break

alertcondition(anyConfirmed, title="型態突破確認", message="技術型態已突破！檢查儀表板。")
alertcondition(resultCount > 0, title="任何型態偵測(含形成中)", message="偵測到技術型態（含形成中）！檢查儀表板。")

// ============================================================
// LAYER 6: TradersPost / IB Automation Webhook
// 已突破訊號 → TradersPost JSON → IB 自動下單
// 設定：Add Alert → Condition: 本 indicator → Any alert() function call → 貼 webhook URL
// ============================================================
group_tp = "═══ TradersPost / IB Automation ═══"
useTP        = input.bool(false, "啟用 TradersPost webhook", group=group_tp,
                          tooltip="關 = 純看圖；開 = 已突破訊號達標時 alert() 出 TradersPost JSON")
tpWatchlist  = input.string("SOFI", "Watchlist (逗號分隔，空=不過濾)", group=group_tp,
                            tooltip="例 SOFI,SOXL,TSLA。每個 ticker 圖表還是要分別設 alert；這裡是防錯白名單。")
tpRiskDollar = input.float(25.0, "單筆風險金額 ($)", minval=1.0, step=1.0, group=group_tp,
                           tooltip="$500 帳戶建議 $25 (5%)。TradersPost 自動算股數 = 此值 ÷ (entry-stop)")
tpMinQuality = input.int(70, "最低品質分 (live trading)", minval=0, maxval=100, group=group_tp,
                         tooltip="高於 v2.0 主面板 minQuality；此值專為自動下單把關")
tpMinRR      = input.float(1.5, "最低 R:R 比 (live trading)", minval=1.0, maxval=5.0, step=0.1, group=group_tp)
tpAllowLong  = input.bool(true,  "啟用做多訊號", group=group_tp)
tpAllowShort = input.bool(false, "啟用做空訊號", group=group_tp,
                          tooltip="美股 cash 帳戶不能 short；只有 margin 帳戶才開")

// ─── Watchlist 過濾（P3-5：array 操作放巢狀 if 而非條件鏈內） ───
tpInWatchlist() =>
    string trimmed = str.replace_all(tpWatchlist, " ", "")
    if str.length(trimmed) == 0
        true
    else
        array<string> wl = str.split(trimmed, ",")
        array.includes(wl, syminfo.ticker)

// ─── Layer 6 主邏輯 ───
// 取 priority-0 的型態（resName[0] = 排序後最高品質的「已突破」訊號）
// 巢狀 if：先確認 resultCount > 0，才碰 array.get（避 P3-5）
// tpFired tracker：給下面 plotshape 用，避免在條件鏈裡放 array.get
var bool tpFired = false
tpFired := false

if useTP and resultCount > 0 and barstate.isconfirmed and tpInWatchlist()
    if array.get(resState, 0) == "已突破"
        string tpDir   = array.get(resDir, 0)
        float  tpQ     = array.get(resQ, 0)
        float  tpEnt   = array.get(resEntry, 0)
        float  tpStp   = array.get(resStop, 0)
        float  tpTgt   = array.get(resTgt, 0)
        string tpName  = array.get(resName, 0)

        // 方向判定：v2.0 用 ▲/▼ 編碼 dir（line 593 同樣判法）
        bool tpIsBull = str.contains(tpDir, "▲")
        bool tpIsBear = str.contains(tpDir, "▼")

        // R:R（與 dashboard 一致：abs(tgt-ent) / abs(ent-stp)）
        float tpRR = not na(tpEnt) and not na(tpStp) and not na(tpTgt) ? safe_div(math.abs(tpTgt - tpEnt), math.abs(tpEnt - tpStp)) : 0.0

        // 進一步把關（v2.0 已有 minQuality/minRR，這裡是 live-trading 加嚴）
        bool tpQualOK   = tpQ >= tpMinQuality
        bool tpRROK     = tpRR >= tpMinRR
        bool tpPricesOK = not na(tpEnt) and not na(tpStp) and not na(tpTgt) and tpStp > 0 and tpTgt > 0
        bool tpDirOK    = (tpIsBull and tpAllowLong and tpStp < tpEnt) or (tpIsBear and tpAllowShort and tpStp > tpEnt)

        if tpQualOK and tpRROK and tpPricesOK and tpDirOK
            string tpAction = tpIsBull ? "buy" : "sell"
            string tpMsg = '{' +
              '"ticker":"' + syminfo.ticker + '",' +
              '"action":"' + tpAction + '",' +
              '"orderType":"market",' +
              '"quantityType":"risk_dollar_amount",' +
              '"quantity":' + str.tostring(tpRiskDollar, "#.##") + ',' +
              '"stopLoss":{"type":"stop","stopPrice":' + str.tostring(tpStp, "#.####") + '},' +
              '"takeProfit":{"limitPrice":' + str.tostring(tpTgt, "#.####") + '},' +
              '"signalPrice":' + str.tostring(close, "#.####") + ',' +
              '"timeInForce":"day",' +
              '"extras":{' +
                '"pattern":"' + tpName + '",' +
                '"quality":' + str.tostring(tpQ, "#") + ',' +
                '"rr":' + str.tostring(tpRR, "#.##") + ',' +
                '"interval":"' + timeframe.period + '",' +
                '"version":"v2.0"' +
              '}' +
            '}'
            alert(tpMsg, alert.freq_once_per_bar_close)
            tpFired := true

// 圖上視覺確認（菱形，讓你肉眼看到 alert 觸發位置）
plotshape(tpFired, title="TP Alert Bar", style=shape.diamond, location=location.belowbar, color=color.new(#00d2ff, 0), size=size.tiny)
